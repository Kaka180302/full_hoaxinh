@model HoaXinhStore.Web.ViewModels.CartPageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giỏ hàng - HoaXinh Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/style.css" />
    <link rel="stylesheet" href="~/storefront.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="nav-only-page">
    <partial name="Partials/_HeaderNavOnly" model='new HoaXinhStore.Web.ViewModels.StoreIndexViewModel()' />

    <main class="store-checkout-page">
        <div class="container">
            <div class="store-breadcrumb">
                <a asp-controller="Store" asp-action="Index"><i class="fa-solid fa-house"></i> Trang chủ</a>
                <span>›</span>
                <strong><i class="fa-solid fa-cart-shopping"></i> Giỏ hàng</strong>
            </div>
            <h1 class="store-page-title">Giỏ hàng</h1>
            <p class="store-page-subtitle">Kiểm tra sản phẩm trước khi đặt hàng</p>

            <section class="cart-box">
                <div id="cartPageEmpty" class="cart-empty d-none">Giỏ hàng trống.</div>
                <div id="cartTableWrap">
                    <div class="cart-head">
                        <div class="cart-head-check">
                            <label class="cart-check-all">
                                <input type="checkbox" id="cartSelectAll" />
                                <span>Tất cả</span>
                            </label>
                        </div>
                        <div class="cart-head-product"><i class="fa-solid fa-box-open"></i> Sản phẩm</div>
                        <div class="cart-head-unit"><i class="fa-solid fa-boxes-stacked"></i> Đơn vị</div>
                        <div class="cart-head-price"><i class="fa-solid fa-tag"></i> Giá</div>
                        <div class="cart-head-qty"><i class="fa-solid fa-hashtag"></i> Số lượng</div>
                        <div class="cart-head-total"><i class="fa-solid fa-money-bill-wave"></i> Thành tiền</div>
                        <div class="cart-head-action"></div>
                    </div>
                    <div id="cartPageItems" class="cart-items"></div>
                    <div id="cartPagination" class="cart-pagination"></div>
                </div>
            </section>

            <section class="cart-actions">
                <button type="button" class="btn-text" id="btnReloadCart"><i class="fa-solid fa-rotate-right"></i> Cập nhật lại</button>
                <a asp-controller="Store" asp-action="Products" class="btn-text"><i class="fa-solid fa-arrow-left"></i> Tiếp tục mua sắm</a>
                <a asp-controller="Store" asp-action="Checkout" class="btn-dark" id="btnToCheckout"><i class="fa-solid fa-credit-card"></i> Thanh toán</a>
                <div class="subtotal">
                    <strong class="subtotal-label"><i class="fa-solid fa-receipt"></i><span>Tạm tính</span></strong>
                    <span id="cartPageTotal">0 đ</span>
                </div>
            </section>
        </div>
    </main>

    <partial name="Partials/_Footer" />
    <script src="~/script.js"></script>
    <script src="~/storefront.js"></script>
</body>
</html>
