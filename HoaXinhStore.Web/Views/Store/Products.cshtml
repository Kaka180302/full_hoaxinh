@model HoaXinhStore.Web.ViewModels.ProductListPageViewModel
@{
    Layout = null;
    var vi = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var selectedCategories = (Model.Category ?? "all")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    if (selectedCategories.Count == 0) selectedCategories.Add("all");
    var selectedBrands = (Model.Brand ?? "all")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    if (selectedBrands.Count == 0) selectedBrands.Add("all");
    var selectedPriceRanges = (Model.PriceRanges ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var selectedStatuses = (Model.StatusFilters ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(x => x.ToLowerInvariant())
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var rootCategories = (Model.Categories ?? new List<HoaXinhStore.Web.ViewModels.StoreCategoryViewModel>())
        .Where(c => !c.ParentCategoryId.HasValue)
        .OrderBy(c => c.Name)
        .ToList();
    var categoryChildren = (Model.Categories ?? new List<HoaXinhStore.Web.ViewModels.StoreCategoryViewModel>())
        .Where(c => c.ParentCategoryId.HasValue)
        .GroupBy(c => c.ParentCategoryId!.Value)
        .ToDictionary(g => g.Key, g => g.OrderBy(x => x.Name).ToList());
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sản phẩm - HoaXinh Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/style.css" />
    <link rel="stylesheet" href="~/storefront.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="nav-only-page products-page">
    <partial name="Partials/_HeaderNavOnly" model='new HoaXinhStore.Web.ViewModels.StoreIndexViewModel { Categories = Model.Categories }' />

    <main class="products-luxe-page @( (!string.IsNullOrWhiteSpace(Model.FilterLabel) || !string.IsNullOrWhiteSpace(Model.Query) || Model.Category != "all" || Model.MinPrice.HasValue || Model.MaxPrice.HasValue) ? "is-filtered" : "" )">
        <div class="container py-3">
            <h1 class="products-luxe-title">Sản phẩm</h1>
            <form method="get" class="products-luxe-toolbar products-luxe-toolbar--search-only" id="productsSearchForm">
                <input type="hidden" name="category" value="@Model.Category" />
                <input type="hidden" name="brand" value="@Model.Brand" />
                <input type="hidden" name="priceRanges" value="@Model.PriceRanges" />
                <input type="hidden" name="inStockOnly" value="@(Model.InStockOnly ? "true" : "false")" />
                <input type="hidden" name="statusFilters" value="@Model.StatusFilters" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="minPrice" value="@(Model.MinPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
                <input type="hidden" name="maxPrice" value="@(Model.MaxPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")" />
                <input type="hidden" name="filterLabel" value="@Model.FilterLabel" />
                <div class="products-luxe-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" name="q" value="@Model.Query" placeholder="Tìm kiếm ..." />
                </div>
                <button type="submit">Tìm</button>
            </form>

            <div class="products-luxe-body">
                <div class="products-filter-overlay" id="productsFilterOverlay"></div>
                <aside class="products-luxe-sidebar" id="productsLuxeSidebar">
                    <h2 class="products-filter-title">Bộ lọc sản phẩm</h2>
                    <section class="sidebar-box">
                        <h3>Danh mục</h3>
                        <ul class="checkbox-list category-tree-list">
                            @foreach (var parent in rootCategories)
                            {
                                var children = categoryChildren.TryGetValue(parent.Id, out var pChildren)
                                    ? pChildren
                                    : new List<HoaXinhStore.Web.ViewModels.StoreCategoryViewModel>();
                                var parentSelected = selectedCategories.Contains(parent.Slug);
                                var hasCheckedChild = children.Any(x => selectedCategories.Contains(x.Slug));
                                var hasChildren = children.Count > 0;
                                var isOpen = hasCheckedChild || parentSelected;
                                <li class="category-tree-item @(isOpen ? "open" : "")">
                                    <button type="button"
                                            class="category-tree-toggle @(hasChildren ? "has-children" : "no-children")"
                                            data-category-toggle>
                                        <span>@parent.Name</span>
                                        <i class="fa-solid fa-angle-down"></i>
                                    </button>
                                    <ul class="checkbox-list category-tree-children" @(isOpen ? "" : "hidden")>
                                        <li>
                                            <label class="category-tree-all">
                                                <input type="checkbox" class="js-category-filter" value="@parent.Slug" @(parentSelected ? "checked" : "") />
                                                Tất cả
                                            </label>
                                        </li>
                                        @foreach (var child in children)
                                        {
                                            <li>
                                                <label>
                                                    <input type="checkbox" class="js-category-filter" value="@child.Slug" @(selectedCategories.Contains(child.Slug) ? "checked" : "") />
                                                    @child.Name
                                                </label>
                                            </li>
                                        }
                                    </ul>
                                </li>
                            }
                        </ul>
                    </section>
                    <section class="sidebar-box">
                        <h3>Khoảng giá</h3>
                        <ul class="checkbox-list">
                            <li>
                                <label>
                                    <input type="checkbox" class="js-price-range js-price-all" data-range="" @(!selectedPriceRanges.Any() ? "checked" : "") />
                                    Tất cả
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-price-range" data-range="0-100000" @(selectedPriceRanges.Contains("0-100000") ? "checked" : "") />
                                    Dưới 100.000đ
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-price-range" data-range="100000-500000" @(selectedPriceRanges.Contains("100000-500000") ? "checked" : "") />
                                    100.000đ - 500.000đ
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-price-range" data-range="500000-1000000" @(selectedPriceRanges.Contains("500000-1000000") ? "checked" : "") />
                                    500.000đ - 1.000.000đ
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-price-range" data-range="1000000-plus" @(selectedPriceRanges.Contains("1000000-plus") ? "checked" : "") />
                                    Trên 1.000.000đ
                                </label>
                            </li>
                        </ul>
                    </section>
                    <section class="sidebar-box">
                        <h3>Thương hiệu</h3>
                        <ul class="checkbox-list">
                            <li>
                                <label>
                                    <input type="checkbox" class="js-filter-multi" data-filter="brand" value="all" @(Model.Brand == "all" ? "checked" : "") />
                                    Tất cả
                                </label>
                            </li>
                            @foreach (var b in Model.Brands)
                            {
                                <li>
                                    <label>
                                        <input type="checkbox" class="js-filter-multi" data-filter="brand" value="@b" @(selectedBrands.Contains(b) ? "checked" : "") />
                                        @b
                                    </label>
                                </li>
                            }
                        </ul>
                    </section>
                    <section class="sidebar-box">
                        <h3>Tình trạng</h3>
                        <ul class="checkbox-list">
                            <li>
                                <label>
                                    <input type="checkbox" class="js-status-filter" value="in-stock" @(selectedStatuses.Contains("in-stock") || Model.InStockOnly ? "checked" : "") />
                                    Còn hàng
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-status-filter" value="bestseller" @(selectedStatuses.Contains("bestseller") ? "checked" : "") />
                                    Bán chạy
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-status-filter" value="featured" @(selectedStatuses.Contains("featured") ? "checked" : "") />
                                    Nổi bật
                                </label>
                            </li>
                            <li>
                                <label>
                                    <input type="checkbox" class="js-status-filter" value="sale" @(selectedStatuses.Contains("sale") ? "checked" : "") />
                                    Khuyến mãi
                                </label>
                            </li>
                        </ul>
                    </section>
                    <section class="sidebar-box">
                        <h3>Sắp xếp</h3>
                        <ul class="checkbox-list">
                            <li><label><input type="radio" class="js-sort-radio" name="sort_radio" value="newest" @(Model.Sort == "newest" ? "checked" : "") /> Mới nhất</label></li>
                            <li><label><input type="radio" class="js-sort-radio" name="sort_radio" value="price-asc" @(Model.Sort == "price-asc" ? "checked" : "") /> Giá tăng dần</label></li>
                            <li><label><input type="radio" class="js-sort-radio" name="sort_radio" value="price-desc" @(Model.Sort == "price-desc" ? "checked" : "") /> Giá giảm dần</label></li>
                            <li><label><input type="radio" class="js-sort-radio" name="sort_radio" value="name-asc" @(Model.Sort == "name-asc" ? "checked" : "") /> Tên A-Z</label></li>
                            <li><label><input type="radio" class="js-sort-radio" name="sort_radio" value="name-desc" @(Model.Sort == "name-desc" ? "checked" : "") /> Tên Z-A</label></li>
                        </ul>
                    </section>
                </aside>

                <section class="products-luxe-content">

                    <div class="products-luxe-grid">
                        @if (!Model.Products.Any())
                        {
                            <div class="products-empty-state">
                                <i class="fa-regular fa-face-frown-open"></i>
                                <p>Không có sản phẩm phù hợp.</p>
                            </div>
                        }
                        else
                        {
                            foreach (var p in Model.Products)
                            {
                                var image = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/logo/hoa_xinh_group_fav.png" : p.ImageUrl;
                                var cardDefaultVariant = (p.Variants ?? new List<HoaXinhStore.Web.ViewModels.StoreVariantViewModel>())
                                    .OrderByDescending(v => v.IsDefault)
                                    .ThenBy(v => v.Id)
                                    .FirstOrDefault();
                                var cardPrice = cardDefaultVariant?.Price ?? p.Price;
                                var cardSale = cardDefaultVariant?.SalePrice;
                                var cardActive = cardSale ?? cardPrice;
                                <article class="luxe-card" data-category="@p.CategorySlug">
                                    <a asp-controller="Store" asp-action="ProductDetail" asp-route-id="@p.Id" class="luxe-card__img">
                                        <img src="@image" alt="@p.Name" />
                                    </a>
                                    <button type="button" class="luxe-fav" aria-label="Yêu thích"><i class="fa-regular fa-heart"></i></button>
                                    <h3><a asp-controller="Store" asp-action="ProductDetail" asp-route-id="@p.Id" class="no_link">@p.Name</a></h3>
                                    <div class="luxe-price">
                                        <strong>@cardActive.ToString("N0", vi) đ</strong>
                                        @if (cardSale.HasValue && cardSale.Value > 0 && cardSale.Value < cardPrice)
                                        {
                                            <span>@cardPrice.ToString("N0", vi) đ</span>
                                        }
                                    </div>
                                    @if (p.StockQuantity <= 0)
                                    {
                                        <button type="button"
                                                class="luxe-add luxe-add-preorder"
                                                data-preorder-popup
                                                data-id="@p.Id"
                                                data-name="@p.Name">Đặt trước</button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="luxe-add"
                                                data-add-cart
                                                data-id="@p.Id"
                                                data-name="@p.Name"
                                                data-price="@cardPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-sale-price="@(cardSale?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                data-stock="@Math.Max(0, p.StockQuantity)"
                                                data-image="@image"><i class="fa-solid fa-cart-shopping"></i></button>
                                    }
                                </article>
                            }
                        }
                    </div>
                </section>
            </div>
        </div>
    </main>

    <partial name="Partials/_Footer" />
    <script src="~/storefront.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchForm = document.getElementById("productsSearchForm");
            if (!searchForm) return;
            const mobileFilterBtn = document.getElementById("mobileFilterBtn");
            const sidebar = document.getElementById("productsLuxeSidebar");
            const overlay = document.getElementById("productsFilterOverlay");
            const categoryInput = searchForm.querySelector('input[name="category"]');
            const brandInput = searchForm.querySelector('input[name="brand"]');
            const stockInput = searchForm.querySelector('input[name="inStockOnly"]');
            const statusFiltersInput = searchForm.querySelector('input[name="statusFilters"]');
            const sortInput = searchForm.querySelector('input[name="sort"]');
            const minPriceInput = searchForm.querySelector('input[name="minPrice"]');
            const maxPriceInput = searchForm.querySelector('input[name="maxPrice"]');
            const priceRangesInput = searchForm.querySelector('input[name="priceRanges"]');

            document.querySelectorAll(".js-sort-radio").forEach(function (radio) {
                radio.addEventListener("change", function () {
                    if (!radio.checked) return;
                    if (sortInput) sortInput.value = radio.value || "newest";
                    searchForm.submit();
                });
            });

            function wireMultiFilter(filterName, hiddenInput) {
                const boxes = Array.from(document.querySelectorAll(`.js-filter-multi[data-filter="${filterName}"]`));
                if (!boxes.length || !hiddenInput) return;
                const allBox = boxes.find(b => (b.value || "").toLowerCase() === "all");
                boxes.forEach(function (box) {
                    box.addEventListener("change", function () {
                        if (box === allBox && box.checked) {
                            boxes.forEach(b => { if (b !== allBox) b.checked = false; });
                        } else if (box !== allBox && box.checked && allBox) {
                            allBox.checked = false;
                        }

                        const selected = boxes
                            .filter(b => b !== allBox && b.checked)
                            .map(b => b.value)
                            .filter(v => !!v);

                        if (!selected.length) {
                            if (allBox) allBox.checked = true;
                            hiddenInput.value = "all";
                        } else {
                            hiddenInput.value = selected.join(",");
                        }
                        searchForm.submit();
                    });
                });
            }
            wireMultiFilter("brand", brandInput);

            document.querySelectorAll(".js-category-filter").forEach(function (box) {
                box.addEventListener("change", function () {
                    const selected = Array.from(document.querySelectorAll(".js-category-filter:checked"))
                        .map(cb => (cb.value || "").trim())
                        .filter(Boolean);
                    if (categoryInput) {
                        categoryInput.value = selected.length ? selected.join(",") : "all";
                    }
                    searchForm.submit();
                });
            });

            document.querySelectorAll("[data-category-toggle]").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    const item = btn.closest(".category-tree-item");
                    const panel = item?.querySelector(".category-tree-children");
                    if (!item || !panel) return;
                    const isOpen = item.classList.contains("open");
                    item.classList.toggle("open", !isOpen);
                    panel.hidden = isOpen;
                });
            });

            document.querySelectorAll(".js-price-range").forEach(function (checkbox) {
                checkbox.addEventListener("change", function () {
                    const allBox = document.querySelector(".js-price-all");
                    const allRanges = Array.from(document.querySelectorAll(".js-price-range:not(.js-price-all)"));
                    if (checkbox.classList.contains("js-price-all") && checkbox.checked) {
                        allRanges.forEach(cb => cb.checked = false);
                    } else if (!checkbox.classList.contains("js-price-all") && checkbox.checked && allBox) {
                        allBox.checked = false;
                    }

                    const selectedRanges = allRanges
                        .filter(cb => cb.checked)
                        .map(cb => cb.getAttribute("data-range") || "")
                        .filter(Boolean);

                    if (!selectedRanges.length) {
                        if (allBox) allBox.checked = true;
                        if (priceRangesInput) priceRangesInput.value = "";
                        if (minPriceInput) minPriceInput.value = "";
                        if (maxPriceInput) maxPriceInput.value = "";
                    } else {
                        if (priceRangesInput) priceRangesInput.value = selectedRanges.join(",");
                        if (minPriceInput) minPriceInput.value = "";
                        if (maxPriceInput) maxPriceInput.value = "";
                    }
                    document.querySelectorAll(".js-price-range").forEach(function (cb) {
                        if (cb !== checkbox && checkbox.classList.contains("js-price-all") && checkbox.checked) cb.checked = false;
                    });
                    searchForm.submit();
                });
            });

            document.querySelectorAll(".js-status-filter").forEach(function (checkbox) {
                checkbox.addEventListener("change", function () {
                    const selected = Array.from(document.querySelectorAll(".js-status-filter:checked"))
                        .map(cb => (cb.value || "").trim())
                        .filter(Boolean);
                    if (statusFiltersInput) statusFiltersInput.value = selected.join(",");
                    if (stockInput) stockInput.value = selected.includes("in-stock") ? "true" : "false";
                    searchForm.submit();
                });
            });

            function closeMobileFilter() {
                sidebar?.classList.remove("open");
                overlay?.classList.remove("open");
                document.body.classList.remove("filter-open");
            }
            function openMobileFilter() {
                sidebar?.classList.add("open");
                overlay?.classList.add("open");
                document.body.classList.add("filter-open");
            }
            mobileFilterBtn?.addEventListener("click", function () {
                if (!sidebar) return;
                if (sidebar.classList.contains("open")) closeMobileFilter();
                else openMobileFilter();
            });
            overlay?.addEventListener("click", closeMobileFilter);
            window.addEventListener("resize", function () {
                if (window.innerWidth > 992) closeMobileFilter();
            });

        });
    </script>
</body>
</html>

