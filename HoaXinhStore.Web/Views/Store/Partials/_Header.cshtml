@model HoaXinhStore.Web.ViewModels.StoreIndexViewModel
@using Microsoft.EntityFrameworkCore
@inject HoaXinhStore.Web.Data.AppDbContext AppDb
@inject HoaXinhStore.Web.Services.HomeContent.IHomeContentService HomeContentService
@{
    var headerCategories = (Model?.Categories ?? new List<HoaXinhStore.Web.ViewModels.StoreCategoryViewModel>()).ToList();
    if (headerCategories.Count == 0)
    {
        headerCategories = await AppDb.Categories
            .AsNoTracking()
            .Where(c => c.IsActive)
            .OrderBy(c => c.Name)
            .Select(c => new HoaXinhStore.Web.ViewModels.StoreCategoryViewModel
            {
                Id = c.Id,
                ParentCategoryId = c.ParentCategoryId,
                Name = c.Name,
                Slug = string.IsNullOrWhiteSpace(c.Slug) ? "all" : c.Slug
            })
            .ToListAsync();
    }

    var parentCategories = headerCategories
        .Where(c => !c.ParentCategoryId.HasValue)
        .OrderBy(c => c.Name)
        .ToList();

    var childCategoryMap = headerCategories
        .Where(c => c.ParentCategoryId.HasValue)
        .GroupBy(c => c.ParentCategoryId!.Value)
        .ToDictionary(g => g.Key, g => g.OrderBy(x => x.Name).ToList());
    var homeContent = await HomeContentService.GetAsync();
    var bannerImages = (homeContent.BannerImages ?? new List<string>())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Take(8)
        .ToList();
    if (!bannerImages.Any())
    {
        bannerImages.Add("/assets/img/banner/banner.jpg");
    }
    var bannerVer = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    string WithBannerVersion(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return string.Empty;
        return url.Contains('?') ? $"{url}&v={bannerVer}" : $"{url}?v={bannerVer}";
    }
    var sliderImages = new List<string>();
    sliderImages.Add(WithBannerVersion(bannerImages.Last()));
    sliderImages.AddRange(bannerImages.Select(WithBannerVersion));
    sliderImages.Add(WithBannerVersion(bannerImages.First()));
}

<header class="header">
    <div id="no_show" class="header_mobile">
        <a href="#" class="header_logoLink no_link">
            <img class="header_logo" src="~/assets/img/logo/Logo_HX.png">
        </a>
        <div class="hx-mobile-lang-center notranslate" role="group" aria-label="Chọn ngôn ngữ">
            <button class="lang-flag" data-lang="vi" title="Tiếng Việt" aria-label="Tiếng Việt">
                <img src="~/assets/img/language/vietnam.png" class="flag_1" />
            </button>
            <button class="lang-flag" data-lang="en" title="English" aria-label="English">
                <img src="~/assets/img/language/united-kingdom.png" class="flag_1" />
            </button>
            <button class="lang-flag" data-lang="ko" title="한국어" aria-label="Korean">
                <img src="~/assets/img/language/ko.png" class="flag_1" />
            </button>
        </div>

        <div class="header_mobileWrap">
            <div title="Giỏ hàng" class="icon_cartWrap">
                <a asp-controller="Store" asp-action="Cart" class="cart_iconLink">
                    <svg id="icon_cart" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-4">
                        <circle cx="8" cy="21" r="1"></circle>
                        <circle cx="19" cy="21" r="1"></circle>
                        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                    </svg>
                    <span id="cart_count" class="cart_count">0</span>
                </a>
            </div>

            <button class="menu_toggle" id="menuToggle">
                <svg class="icon_mobile" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                    <path d="M96 160C96 142.3 110.3 128 128 128L512 128C529.7 128 544 142.3 544 160C544 177.7 529.7 192 512 192L128 192C110.3 192 96 177.7 96 160zM96 320C96 302.3 110.3 288 128 288L512 288C529.7 288 544 302.3 544 320C544 337.7 529.7 352 512 352L128 352C110.3 352 96 337.7 96 320zM544 480C544 497.7 529.7 512 512 512L128 512C110.3 512 96 497.7 96 480C96 462.3 110.3 448 128 448L512 448C529.7 448 544 462.3 544 480z" />
                </svg>
            </button>
        </div>
    </div>
    <div class="slider">

        <div class="menu_nav">
            <div class="menu_nav--btnClose">
                <button id="btn_close" class="menu_nav--close">✕</button>
            </div>
            <div class="header_nav">
                <ul class="header_navList no_list">
                    <li class="header_navList--item">
                        <a asp-controller="Store" asp-action="Products" class="header_navList--link no_link">Danh mục</a>
                    </li>
                    <li class="header_navList--item">
                        <a asp-controller="Store" asp-action="Products" class="header_navList--link no_link">Sản phẩm</a>
                    </li>
                    @if (homeContent.ShowFeaturedSection)
                    {
                        <li class="header_navList--item">
                            <a href="#featured" class="header_navList--link no_link">Nổi bật</a>
                        </li>
                    }
                    <li class="header_navList--item">
                        <a asp-controller="Store" asp-action="TrackOrder" class="header_navList--link no_link">Tra cứu đơn hàng</a>
                    </li>
                </ul>
            </div>
        </div>

        <div id="no_header" class="header_info">
            <div class="header_wrap">
                <a href="#" class="header_logoLink no_link">
                    <img class="header_logo" src="~/assets/img/logo/Logo_HX.png" alt="Logo_Hoa_Xinh">
                </a>
                <div class="header_nav">
                    <ul class="header_navList no_list">
                        <li class="header_navList--item header_navList--item-cats">
                            <a href="javascript:void(0)" class="header_navList--link no_link">Danh mục</a>
                            <div class="menu_categories">
                                <div class="menu_categories-left">
                                    @for (var i = 0; i < parentCategories.Count; i++)
                                    {
                                        var parent = parentCategories[i];
                                        var children = childCategoryMap.TryGetValue(parent.Id, out var c)
                                            ? c
                                            : new List<HoaXinhStore.Web.ViewModels.StoreCategoryViewModel>();
                                        <div class="menu_categories-parent-wrap @(i == 0 ? "is-default" : "")">
                                            <a asp-controller="Store"
                                               asp-action="Products"
                                               asp-route-category="@parent.Slug"
                                               class="menu_categories-parent-item @(children.Count > 0 ? "has-children" : "")">
                                                <span>@parent.Name</span>
                                                @if (children.Count > 0)
                                                {
                                                    <i class="fa-solid fa-angle-right"></i>
                                                }
                                            </a>
                                            <div class="menu_categories-right @(children.Count == 0 ? "is-empty" : "")">
                                                <h4>@parent.Name</h4>
                                                @if (children.Count > 0)
                                                {
                                                    <div class="menu_categories-children">
                                                        @foreach (var child in children)
                                                        {
                                                            <a asp-controller="Store"
                                                               asp-action="Products"
                                                               asp-route-category="@child.Slug"
                                                               class="menu_categories-child-item">@child.Name</a>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </li>

                        <li class="header_navList--item">
                            <a asp-controller="Store" asp-action="Products" class="header_navList--link no_link">Sản phẩm</a>
                        </li>

                        @if (homeContent.ShowFeaturedSection)
                        {
                            <li class="header_navList--item">
                                <a href="#featured" class="header_navList--link no_link">Nổi bật</a>
                            </li>
                        }
                        <li class="header_navList--item">
                            <a asp-controller="Store" asp-action="TrackOrder" class="header_navList--link no_link">Tra cứu đơn hàng</a>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="language_top">
                <div class="lang-switch notranslate">
                    <div id="google_translate_element" aria-hidden="true"></div>
                    <div class="lang-flags" role="group" aria-label="Chọn ngôn ngữ">
                        <button class="lang-flag" data-lang="vi" title="Tiếng Việt" aria-label="Tiếng Việt">
                            <img src="~/assets/img/language/vietnam.png" class="flag_1" />
                        </button>
                        <button class="lang-flag" data-lang="en" title="English" aria-label="English">
                            <img src="~/assets/img/language/united-kingdom.png" class="flag_1" />
                        </button>
                        <button class="lang-flag" data-lang="ko" title="한국어" aria-label="Korean">
                            <img src="~/assets/img/language/ko.png" class="flag_1" />
                        </button>
                    </div>
                </div>
            </div>
            <div title="Giỏ hàng" class="icon_cartWrap cart-hover-wrap">
                <a asp-controller="Store" asp-action="Cart" class="cart_iconLink">
                    <svg id="icon_cart" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-4">
                        <circle cx="8" cy="21" r="1"></circle>
                        <circle cx="19" cy="21" r="1"></circle>
                        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                    </svg>
                    <span id="cart_count" class="cart_count">0</span>
                </a>
                <div class="mini-cart-preview shadow">
                    <div data-mini-cart-content class="mini-cart-content"></div>
                </div>
            </div>
        </div>

        @for (var i = 0; i < bannerImages.Count; i++)
        {
            <input type="radio" name="slider_check" id="s@(i + 1)" @(i == 0 ? "checked" : "")>
        }
        <div class="slider_item">
            @for (var i = 0; i < sliderImages.Count; i++)
            {
                <img src="@sliderImages[i]" alt="banner-@(i + 1)">
            }
        </div>
        <div class="slider_navigation">
            @for (var i = 0; i < bannerImages.Count; i++)
            {
                <label for="s@(i + 1)"></label>
            }
        </div>
    </div>
</header>
<script>
    if (typeof window.googleTranslateElementInit !== "function") {
        window.googleTranslateElementInit = function () {
            if (!window.google || !google.translate || !google.translate.TranslateElement) return;
            new google.translate.TranslateElement({
                pageLanguage: "vi",
                includedLanguages: "ko,vi,en",
                autoDisplay: false,
                layout: google.translate.TranslateElement.InlineLayout.HORIZONTAL
            }, "google_translate_element");
        };
    }
</script>
<script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<script src="~/language.js" asp-append-version="true"></script>
