@model HoaXinhStore.Web.ViewModels.StoreIndexViewModel
@{
    Layout = null;
    var checkoutMessage = TempData["CheckoutMessage"] as string;
    var checkoutStatus = TempData["CheckoutStatus"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HoaXinh Store</title>
    <link rel="stylesheet" href="~/assets/style.css">
    <link rel="stylesheet" href="~/storefront.css" />
    <link rel="shortcut icon" type="image/png" href="~/assets/img/logo/hoa_xinh_group_fav.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="hx-home2">
    <div class="hx-home2-shell">
        <partial name="Partials/_Header" model="Model" />

        <main class="hx-home2-main">
            <section id="featured" class="hxs-f5-section">
                <div class="hxs-f5-head">
                    <h2 class="hxs-f5-title">Sản phẩm nổi bật</h2>
                    <a href="/Store/Products?filterLabel=S%E1%BA%A3n%20ph%E1%BA%A9m%20n%E1%BB%95i%20b%E1%BA%ADt" class="hxs-f5-viewall">Xem tất cả</a>
                </div>
                @{
                    var picks = Model.FeaturedProducts.ToList();
                }
                <div class="hxs-f5-slider" data-f5-slider>
                    <button type="button" class="hxs-f5-nav hxs-f5-prev" data-f5-prev aria-label="Sản phẩm trước">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <div class="hxs-f5-viewport" data-f5-viewport>
                        <div class="hxs-f5-track" data-f5-track>
                            @foreach (var p in picks)
                            {
                                var img = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/logo/hoa_xinh_group_fav.png" : p.ImageUrl;
                                var cardDefaultVariant = (p.Variants ?? new List<HoaXinhStore.Web.ViewModels.StoreVariantViewModel>())
                                    .OrderByDescending(v => v.IsDefault)
                                    .ThenBy(v => v.Id)
                                    .FirstOrDefault();
                                var cardPrice = cardDefaultVariant?.Price ?? p.Price;
                                var cardSale = cardDefaultVariant?.SalePrice;
                                var cardActive = cardSale ?? cardPrice;
                                <article class="hxs-f5-card" data-f5-card>
                                    <a href="/Store/ProductDetail/@p.Id" class="hxs-f5-media">
                                        <img src="@img" alt="@p.Name">
                                    </a>
                                    <h3 class="hxs-f5-name"><a href="/Store/ProductDetail/@p.Id">@p.Name</a></h3>
                                    <div class="hxs-f5-price">
                                        <strong>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} đ", cardActive)</strong>
                                        @if (cardSale.HasValue && cardSale.Value > 0 && cardSale.Value < cardPrice)
                                        {
                                            <span>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} đ", cardPrice)</span>
                                        }
                                    </div>
                                    @if (p.StockQuantity <= 0)
                                    {
                                        <button type="button"
                                                class="hxs-f5-action hxs-f5-preorder"
                                                aria-label="Đặt trước"
                                                data-preorder-popup
                                                data-id="@p.Id"
                                                data-name="@p.Name">
                                            Đặt trước
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="hxs-f5-action"
                                                aria-label="Thêm vào giỏ"
                                                data-add-cart
                                                data-id="@p.Id"
                                                data-name="@p.Name"
                                                data-price="@cardPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                data-sale-price="@(cardSale?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                data-stock="@Math.Max(0, p.StockQuantity)"
                                                data-image="@img">
                                            <i class="fa-solid fa-cart-shopping"></i>
                                        </button>
                                    }
                                </article>
                            }
                        </div>
                    </div>
                    <button type="button" class="hxs-f5-nav hxs-f5-next" data-f5-next aria-label="Sản phẩm tiếp theo">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </section>

            @foreach (var catSection in Model.CategorySections)
            {
                <section id="cat-@catSection.Category.Slug" class="hx-home2-section">
                    <div class="hx-home2-section-head">
                        <h2>@catSection.Category.Name</h2>
                        <a href="/Store/Products?category=@catSection.Category.Slug&filterLabel=@Uri.EscapeDataString(catSection.Category.Name)" class="hx-home2-viewall">Xem tất cả</a>
                    </div>
                    <div class="hx-home2-product-grid">
                        @foreach (var p in catSection.Products.Take(5))
                        {
                            var img = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/logo/hoa_xinh_group_fav.png" : p.ImageUrl;
                            var cardDefaultVariant = (p.Variants ?? new List<HoaXinhStore.Web.ViewModels.StoreVariantViewModel>())
                                .OrderByDescending(v => v.IsDefault)
                                .ThenBy(v => v.Id)
                                .FirstOrDefault();
                            var cardPrice = cardDefaultVariant?.Price ?? p.Price;
                            var cardSale = cardDefaultVariant?.SalePrice;
                            var cardActive = cardSale ?? cardPrice;
                            <article class="hx-home2-product-card">
                                <a href="/Store/ProductDetail/@p.Id" class="hx-home2-product-media">
                                    <img src="@img" alt="@p.Name">
                                </a>
                                <h3><a href="/Store/ProductDetail/@p.Id">@p.Name</a></h3>
                                <div class="hx-home2-price">
                                    <strong>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0}đ", cardActive)</strong>
                                    @if (cardSale.HasValue && cardSale.Value > 0 && cardSale.Value < cardPrice)
                                    {
                                        <span>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0}đ", cardPrice)</span>
                                    }
                                </div>
                                @if (p.StockQuantity <= 0)
                                {
                                    <button type="button"
                                            class="hx-home2-addcart-btn hx-home2-preorder-btn"
                                            aria-label="Đặt trước"
                                            data-preorder-popup
                                            data-id="@p.Id"
                                            data-name="@p.Name">
                                        Đặt trước
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="hx-home2-addcart-btn"
                                            aria-label="Thêm vào giỏ"
                                            data-add-cart
                                            data-id="@p.Id"
                                            data-name="@p.Name"
                                            data-price="@cardPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                            data-sale-price="@(cardSale?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                            data-stock="@Math.Max(0, p.StockQuantity)"
                                            data-image="@img">
                                        <i class="fa-solid fa-cart-shopping"></i>
                                    </button>
                                }
                            </article>
                        }
                    </div>
                </section>
            }

            @if (Model.Brands.Any())
            {
                <section class="hx-home2-section">
                    <div class="hx-home2-section-head">
                        <h2>Thương hiệu</h2>
                    </div>
                    <div class="hx-home2-brand-grid">
                        @foreach (var b in Model.Brands)
                        {
                            var brandImage = string.IsNullOrWhiteSpace(b.ImageUrl) ? "/assets/img/logo/hoa_xinh_group_fav.png" : b.ImageUrl;
                            <article class="hx-home2-brand-card">
                                <a href="/Store/Products?brand=@Uri.EscapeDataString(b.Name)&filterLabel=@Uri.EscapeDataString("Thương hiệu: " + b.Name)" class="no_link">
                                    <img src="@brandImage" alt="@b.Name" />
                                    <h3>@b.Name</h3>
                                </a>
                            </article>
                        }
                    </div>
                </section>
            }
        </main>
    </div>

    <partial name="Partials/_Footer" />

    @if (!string.IsNullOrWhiteSpace(checkoutMessage))
    {
        <div class="hx-popup-backdrop" id="homeCheckoutPopup" style="display:none;">
            <div class="hx-popup-card">
                <button type="button" class="hx-popup-close" id="homeCheckoutPopupClose">×</button>
                <div class="hx-popup-body">
                    <h4 id="homeCheckoutPopupTitle">Thông báo</h4>
                    <p id="homeCheckoutPopupMessage">@checkoutMessage</p>
                    <button type="button" class="mini-cart-view-btn" id="homeCheckoutPopupOk">Đã hiểu</button>
                </div>
            </div>
        </div>
        <script>
            window.__checkoutMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(checkoutMessage));
            window.__checkoutStatus = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(checkoutStatus ?? ""));
            (function(){
                const popup = document.getElementById('homeCheckoutPopup');
                if (!popup) return;
                const title = document.getElementById('homeCheckoutPopupTitle');
                const status = (window.__checkoutStatus || '').toLowerCase();
                if (title) {
                    title.textContent = status === 'success'
                        ? 'Thanh toán thành công'
                        : (status === 'cancelled'
                            ? 'Bạn đã hủy thanh toán'
                            : (status === 'error' ? 'Thanh toán thất bại' : 'Thông báo thanh toán'));
                }
                const close = () => popup.style.display = 'none';
                popup.style.display = 'flex';
                document.getElementById('homeCheckoutPopupClose')?.addEventListener('click', close);
                document.getElementById('homeCheckoutPopupOk')?.addEventListener('click', close);
                popup.addEventListener('click', (e) => { if (e.target === popup) close(); });
            })();
        </script>
    }

    <script src="~/storefront.js"></script>
</body>
</html>

