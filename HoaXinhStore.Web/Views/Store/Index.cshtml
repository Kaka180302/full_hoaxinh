@model HoaXinhStore.Web.ViewModels.StoreIndexViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HoaXinh Store</title>
    <link rel="stylesheet" href="~/assets/style.css">
    <link rel="stylesheet" href="~/storefront.css" />
    <link rel="shortcut icon" type="image/png" href="~/assets/img/hoa_xinh_group_fav.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
</head>
<body class="hx-home2">
    <div class="hx-home2-shell">
        <partial name="Partials/_Header" model="Model" />

        <main class="hx-home2-main">
            <section id="featured" class="hx-home2-section">
                <div class="hx-home2-section-head">
                    <h2 class="top">Sản phẩm nổi bật</h2>
                    <a href="/Store/Products?filterLabel=S%E1%BA%A3n%20ph%E1%BA%A9m%20n%E1%BB%95i%20b%E1%BA%ADt" class="hx-home2-viewall">Xem tất cả</a>
                </div>
                @{
                    var picks = Model.FeaturedProducts.Take(6).ToList();
                    bool IsVideo(string media) => media.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase)
                        || media.EndsWith(".webm", StringComparison.OrdinalIgnoreCase)
                        || media.EndsWith(".ogg", StringComparison.OrdinalIgnoreCase);
                }
                <div class="hx-staff-pick">
                    <div class="hx-staff-col">
                        @foreach (var p in picks.Take(2))
                        {
                            var media = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/hoa_xinh_group_fav.png" : p.ImageUrl;
                            <a class="hx-staff-item hx-staff-small" href="/Store/ProductDetail/@p.Id">
                                @if (IsVideo(media))
                                {
                                    <video src="@media" muted autoplay loop playsinline></video>
                                }
                                else
                                {
                                    <img src="@media" alt="@p.Name" />
                                }
                            </a>
                        }
                    </div>
                    @if (picks.Count > 2)
                    {
                        var center = picks[2];
                        var media = string.IsNullOrWhiteSpace(center.ImageUrl) ? "/assets/img/hoa_xinh_group_fav.png" : center.ImageUrl;
                        <a class="hx-staff-item hx-staff-main" href="/Store/ProductDetail/@center.Id">
                            @if (IsVideo(media))
                            {
                                <video src="@media" muted autoplay loop playsinline></video>
                            }
                            else
                            {
                                <img src="@media" alt="@center.Name" />
                            }
                            <span class="hx-staff-play"><i class="fa-solid fa-play"></i></span>
                        </a>
                    }
                    <div class="hx-staff-col">
                        @foreach (var p in picks.Skip(3).Take(3))
                        {
                            var media = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/hoa_xinh_group_fav.png" : p.ImageUrl;
                            <a class="hx-staff-item hx-staff-small" href="/Store/ProductDetail/@p.Id">
                                @if (IsVideo(media))
                                {
                                    <video src="@media" muted autoplay loop playsinline></video>
                                }
                                else
                                {
                                    <img src="@media" alt="@p.Name" />
                                }
                            </a>
                        }
                    </div>
                </div>
            </section>

            @foreach (var catSection in Model.CategorySections)
            {
                <section id="cat-@catSection.Category.Slug" class="hx-home2-section">
                    <div class="hx-home2-section-head">
                        <h2>@catSection.Category.Name</h2>
                        <a href="/Store/Products?category=@catSection.Category.Slug&filterLabel=@Uri.EscapeDataString(catSection.Category.Name)" class="hx-home2-viewall">Xem tất cả</a>
                    </div>
                    <div class="hx-home2-product-grid">
                        @foreach (var p in catSection.Products)
                        {
                            var img = string.IsNullOrWhiteSpace(p.ImageUrl) ? "/assets/img/hoa_xinh_group_fav.png" : p.ImageUrl;
                            var price = p.SalePrice ?? p.Price;
                            <article class="hx-home2-product-card">
                                <a href="/Store/ProductDetail/@p.Id" class="hx-home2-product-media">
                                    <img src="@img" alt="@p.Name">
                                </a>
                                <h3><a href="/Store/ProductDetail/@p.Id">@p.Name</a></h3>
                                <div class="hx-home2-price">
                                    <strong>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} đ", price)</strong>
                                    @if (p.SalePrice.HasValue && p.SalePrice.Value < p.Price)
                                    {
                                        <span>@string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} đ", p.Price)</span>
                                    }
                                </div>
                                @if (p.StockQuantity <= 0)
                                {
                                    <button type="button"
                                            class="hx-home2-addcart-btn hx-home2-preorder-btn"
                                            aria-label="Đặt trước"
                                            data-preorder-popup
                                            data-id="@p.Id"
                                            data-name="@p.Name">
                                        Đặt trước
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="hx-home2-addcart-btn"
                                            aria-label="Thêm vào giỏ"
                                            data-add-cart
                                            data-id="@p.Id"
                                            data-name="@p.Name"
                                            data-price="@p.Price"
                                            data-sale-price="@(p.SalePrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                            data-stock="@Math.Max(0, p.StockQuantity)"
                                            data-image="@img">
                                        <i class="fa-solid fa-cart-shopping"></i>
                                    </button>
                                }
                            </article>
                        }
                    </div>
                </section>
            }

            @{
                var brands = Model.Products
                    .Where(x => !string.IsNullOrWhiteSpace(x.BrandName) && !string.IsNullOrWhiteSpace(x.BrandImageUrl))
                    .GroupBy(x => x.BrandName.Trim())
                    .Select(g => new { Name = g.Key, Image = g.First().BrandImageUrl })
                    .ToList();
            }
            @if (brands.Any())
            {
                <section class="hx-home2-section">
                    <div class="hx-home2-section-head">
                        <h2>Thương hiệu</h2>
                    </div>
                    <div class="hx-home2-brand-grid">
                        @foreach (var b in brands)
                        {
                            <article class="hx-home2-brand-card">
                                <img src="@b.Image" alt="@b.Name" />
                                <h3>@b.Name</h3>
                            </article>
                        }
                    </div>
                </section>
            }
        </main>
    </div>

    <partial name="Partials/_Footer" />

    <script src="~/script.js"></script>
    <script>
        (function () {
            const CART_KEY = 'cart';
            const cartLink = document.getElementById('hxCartLink') || document.querySelector('.cart_iconLink') || document.querySelector('.store-cart-link');
            const cartCount = document.getElementById('hxCartCount');
            const miniCart = document.getElementById('hxMiniCart') || document.querySelector('[data-mini-cart-content]') || document.getElementById('miniCartContent');
            const stickyHead = document.querySelector('.hx-home2-head');

            function readCart() {
                try {
                    const raw = localStorage.getItem(CART_KEY);
                    return raw ? JSON.parse(raw) : [];
                } catch {
                    return [];
                }
            }

            function writeCart(items) {
                localStorage.setItem(CART_KEY, JSON.stringify(items));
            }

            function formatVnd(value) {
                return Number(value || 0).toLocaleString('vi-VN') + ' đ';
            }

            function effectivePrice(payload) {
                return payload.salePrice != null ? Number(payload.salePrice) : Number(payload.price || 0);
            }

            function updateBadge() {
                const total = readCart().reduce((sum, x) => sum + Number(x.qty || 0), 0);
                if (cartCount) {
                    cartCount.textContent = String(total);
                    cartCount.style.display = total > 0 ? 'inline-flex' : 'none';
                }
                document.querySelectorAll('.cart_count').forEach(el => {
                    el.textContent = String(total);
                    el.style.display = total > 0 ? 'inline-flex' : 'none';
                });
            }

            function renderMiniCart() {
                if (!miniCart) return;
                const items = readCart();
                const isStoreMiniCart = miniCart.classList.contains('mini-cart-content') || miniCart.id === 'miniCartContent';
                if (!items.length) {
                    miniCart.innerHTML = isStoreMiniCart
                        ? '<div class="mini-cart-title">Giỏ hàng</div><div class="mini-cart-empty">Giỏ hàng trống.</div><div class="mini-cart-footer"><a href="/Store/Cart" class="mini-cart-view-btn">Xem giỏ hàng</a></div>'
                        : '<div class="hx-mini-cart-empty">Giỏ hàng trống</div><a href="/Store/Cart" class="hx-mini-cart-view">Xem giỏ hàng</a>';
                    return;
                }
                const latest = items.slice().reverse().slice(0, 4);
                if (isStoreMiniCart) {
                    miniCart.innerHTML = '<div class="mini-cart-title">Giỏ hàng</div>' + latest.map(item => {
                        const line = Number(item.qty || 1) * Number(item.price || 0);
                        return '<div class="mini-cart-item">' +
                            '<img src="' + (item.image || '/assets/img/hoa_xinh_group_fav.png') + '" alt="">' +
                            '<div class="mini-cart-meta"><a class="mini-cart-name" href="/Store/ProductDetail/' + item.id + '">' + (item.name || '') + '</a><span class="mini-cart-price">' + formatVnd(line) + '</span></div>' +
                            '</div>';
                    }).join('') + '<div class="mini-cart-footer"><a href="/Store/Cart" class="mini-cart-view-btn">Xem giỏ hàng</a></div>';
                    return;
                }
                miniCart.innerHTML = latest.map(item => {
                    const line = Number(item.qty || 1) * Number(item.price || 0);
                    return '<a class="hx-mini-cart-item" href="/Store/ProductDetail/' + item.id + '">' +
                        '<img src="' + (item.image || '/assets/img/hoa_xinh_group_fav.png') + '" alt="">' +
                        '<div><h4>' + (item.name || '') + '</h4><p>' + formatVnd(line) + '</p></div>' +
                        '</a>';
                }).join('') + '<a href="/Store/Cart" class="hx-mini-cart-view">Xem giỏ hàng</a>';
            }

            function animateFlyToCart(sourceImg) {
                if (!sourceImg || !cartLink) return;
                const imgRect = sourceImg.getBoundingClientRect();
                const cartRect = cartLink.getBoundingClientRect();
                const clone = sourceImg.cloneNode(true);
                clone.classList.add('hx-fly-item');
                clone.style.left = imgRect.left + 'px';
                clone.style.top = imgRect.top + 'px';
                clone.style.width = imgRect.width + 'px';
                clone.style.height = imgRect.height + 'px';
                document.body.appendChild(clone);

                requestAnimationFrame(() => {
                    clone.style.left = (cartRect.left + cartRect.width / 2 - 12) + 'px';
                    clone.style.top = (cartRect.top + cartRect.height / 2 - 12) + 'px';
                    clone.style.width = '24px';
                    clone.style.height = '24px';
                    clone.style.opacity = '0.2';
                });

                setTimeout(() => clone.remove(), 620);
            }

            function addToCart(payload, sourceImg) {
                const cart = readCart();
                const found = cart.find(x => Number(x.id) === Number(payload.id));
                const stock = Math.max(0, Number(payload.stock || 0));
                const desiredQty = Number(found?.qty || 0) + 1;
                const showNotice = (msg) => {
                    const wrap = document.createElement('div');
                    wrap.className = 'hx-popup-backdrop';
                    wrap.style.display = 'flex';
                    wrap.innerHTML = `<div class="hx-popup-card"><button type="button" class="hx-popup-close">×</button><div class="hx-popup-body"><h4>Thông báo</h4><p>${msg}</p><button type="button" class="mini-cart-view-btn">Đã hiểu</button></div></div>`;
                    document.body.appendChild(wrap);
                    const close = () => wrap.remove();
                    wrap.querySelector('.hx-popup-close')?.addEventListener('click', close);
                    wrap.querySelector('.mini-cart-view-btn')?.addEventListener('click', close);
                    wrap.addEventListener('click', (e) => { if (e.target === wrap) close(); });
                };
                if (stock === 0) return showNotice('Sản phẩm hiện tạm hết hàng.');
                if (desiredQty > stock) {
                    showNotice(`Sản phẩm hiện chỉ còn ${stock} trong kho.`);
                    return;
                }
                const price = effectivePrice(payload);
                if (found) {
                    found.qty = Number(found.qty || 1) + 1;
                    found.price = price;
                    found.image = payload.image;
                    found.name = payload.name;
                    found.salePrice = payload.salePrice;
                    found.originalPrice = Number(payload.price || 0);
                } else {
                    cart.push({
                        id: Number(payload.id),
                        name: payload.name || '',
                        qty: 1,
                        price,
                        originalPrice: Number(payload.price || 0),
                        salePrice: payload.salePrice,
                        image: payload.image || '',
                        checked: true
                    });
                }
                writeCart(cart);
                updateBadge();
                renderMiniCart();
                animateFlyToCart(sourceImg);
            }

            function initFeaturedSlider() {
                const slider = document.getElementById('hxFeaturedSlider');
                const track = document.getElementById('hxFeaturedTrack');
                if (!slider || !track) return;

                const cards = Array.from(track.querySelectorAll('.hx-home2-product-card'));
                if (cards.length < 2) return;

                const frag = document.createDocumentFragment();
                cards.forEach(card => frag.appendChild(card.cloneNode(true)));
                track.appendChild(frag);

                const prevBtn = slider.querySelector('.hx-home2-slider-prev');
                const nextBtn = slider.querySelector('.hx-home2-slider-next');
                let rafId = null;
                let paused = false;
                let x = 0;
                let speed = 0.55;

                function itemStep() {
                    const first = track.querySelector('.hx-home2-product-card');
                    return first ? first.getBoundingClientRect().width + 12 : 220;
                }

                function maxLoop() {
                    return track.scrollWidth / 2;
                }

                function render() {
                    if (!paused) {
                        x += speed;
                        const loop = maxLoop();
                        if (x >= loop) x = 0;
                        track.style.transform = `translate3d(${-x}px,0,0)`;
                    }
                    rafId = requestAnimationFrame(render);
                }

                function moveBy(direction) {
                    x += itemStep() * direction;
                    const loop = maxLoop();
                    if (x < 0) x += loop;
                    if (x >= loop) x -= loop;
                    track.style.transform = `translate3d(${-x}px,0,0)`;
                }

                prevBtn?.addEventListener('click', () => moveBy(-1));
                nextBtn?.addEventListener('click', () => moveBy(1));
                slider.addEventListener('mouseenter', () => { paused = true; });
                slider.addEventListener('mouseleave', () => { paused = false; });

                render();

                window.addEventListener('beforeunload', () => {
                    if (rafId) cancelAnimationFrame(rafId);
                });
            }

            function initStickyHeader() {
                if (!stickyHead) return;
                const sync = () => {
                    stickyHead.classList.toggle('is-scrolled', window.scrollY > 8);
                };
                sync();
                window.addEventListener('scroll', sync, { passive: true });
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('[data-add-cart]');
                if (!btn) return;
                e.preventDefault();
                e.stopPropagation();
                const card = btn.closest('.hx-home2-product-card');
                const img = card ? card.querySelector('img') : null;
                const payload = {
                    id: btn.getAttribute('data-id'),
                    name: btn.getAttribute('data-name'),
                    price: Number(btn.getAttribute('data-price') || 0),
                    salePrice: btn.getAttribute('data-sale-price') ? Number(btn.getAttribute('data-sale-price')) : null,
                    image: btn.getAttribute('data-image'),
                    stock: Number(btn.getAttribute('data-stock') || 0)
                };
                addToCart(payload, img);
            });

            document.addEventListener('click', async function (e) {
                const btn = e.target.closest('[data-preorder-popup]');
                if (!btn) return;
                const name = btn.getAttribute('data-name') || '';
                const pid = Number(btn.getAttribute('data-id') || 0);
                const wrap = document.createElement('div');
                wrap.className = 'hx-popup-backdrop';
                wrap.style.display = 'flex';
                wrap.innerHTML = `<div class="hx-popup-card"><button type="button" class="hx-popup-close">×</button><div class="hx-popup-body"><h4>Đặt trước</h4><p><strong>${name}</strong></p><form id="hxInlinePreorderForm" class="d-grid gap-2"><input class="form-control" name="qty" type="number" min="1" value="" placeholder="Nhập số lượng cần đặt trước"><input class="form-control" name="customerName" placeholder="Họ tên" required><input class="form-control" name="phoneNumber" placeholder="Số điện thoại" required><input class="form-control" name="email" placeholder="Email"><input class="form-control" name="address" placeholder="Địa chỉ"><button class="mini-cart-view-btn" type="submit">Gửi yêu cầu</button></form><div id="hxInlineMsg"></div></div></div>`;
                document.body.appendChild(wrap);
                const close = () => wrap.remove();
                wrap.querySelector('.hx-popup-close')?.addEventListener('click', close);
                wrap.addEventListener('click', (ev) => { if (ev.target === wrap) close(); });
                const form = wrap.querySelector('#hxInlinePreorderForm');
                const msg = wrap.querySelector('#hxInlineMsg');
                form?.addEventListener('submit', async (ev) => {
                    ev.preventDefault();
                    const fd = new FormData(form);
                    const payload = { productId: pid, quantity: Number(fd.get('qty') || 1), customerName: String(fd.get('customerName') || ''), phoneNumber: String(fd.get('phoneNumber') || ''), email: String(fd.get('email') || ''), address: String(fd.get('address') || '') };
                    const res = await fetch('/Store/SubmitPreOrderPopup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                    const data = await res.json();
                    if (msg) msg.textContent = data.message || '';
                    if (data.ok) setTimeout(close, 900);
                });
            });

            cartLink?.addEventListener('click', function (e) {
                if (e.target.closest('.hx-mini-cart-item') || e.target.closest('.hx-mini-cart-view') || e.target.closest('.mini-cart-item') || e.target.closest('.mini-cart-view-btn')) return;
                window.location.href = '/Store/Cart';
            });

            initStickyHeader();
            initFeaturedSlider();
            updateBadge();
            renderMiniCart();
            if (new URLSearchParams(window.location.search).get('orderNo')) {
                const orderLookup = document.getElementById('order-lookup');
                orderLookup?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        })();
    </script>
</body>
</html>
