@model HoaXinhStore.Web.ViewModels.OrderTrackingViewModel
@{
    ViewData["Title"] = "Tra cứu đơn hàng";
}

<div class="container py-4">
    <h2 class="mb-3">Tra cứu đơn hàng</h2>
    <p class="text-muted">Nhập mã đơn và số điện thoại đặt hàng để theo dõi trạng thái xử lý.</p>

    <div class="card mb-4">
        <div class="card-body">
            <form method="post" asp-action="TrackOrder">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Mã đơn hàng</label>
                        <input class="form-control" asp-for="OrderNo" placeholder="Ví dụ: HX20260403123456" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input class="form-control" asp-for="PhoneNumber" placeholder="Ví dụ: 09xxxxxxxx" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-primary" type="submit">Tra cứu</button>
                        <a class="btn btn-secondary" asp-action="Index">Về trang chủ</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasSearched)
    {
        if (!Model.Found)
        {
            <div class="alert alert-warning">@Model.Message</div>
        }
        else if (Model.Order is not null)
        {
            <div class="card">
                <div class="card-header fw-semibold">Kết quả tra cứu</div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-6"><strong>Mã đơn:</strong> @Model.Order.OrderNo</div>
                        <div class="col-md-6"><strong>Ngày tạo:</strong> @Model.Order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                        <div class="col-md-6"><strong>Khách hàng:</strong> @Model.Order.CustomerName</div>
                        <div class="col-md-6"><strong>SĐT:</strong> @Model.Order.PhoneNumber</div>
                        <div class="col-md-12"><strong>Địa chỉ giao hàng:</strong> @Model.Order.ShippingAddress</div>
                        <div class="col-md-6"><strong>Trạng thái đơn:</strong> @Model.Order.OrderStatus</div>
                        <div class="col-md-6"><strong>Trạng thái thanh toán:</strong> @Model.Order.PaymentStatus</div>
                        <div class="col-md-6"><strong>Phương thức thanh toán:</strong> @Model.Order.PaymentMethod</div>
                        <div class="col-md-6"><strong>Tổng tiền:</strong> @Model.Order.TotalAmount.ToString("N0") đ</div>
                        <div class="col-md-6"><strong>Đơn vị vận chuyển:</strong> @(string.IsNullOrWhiteSpace(Model.Order.ShippingCarrier) ? "Đang cập nhật" : Model.Order.ShippingCarrier)</div>
                        <div class="col-md-6"><strong>Mã vận đơn:</strong> @(string.IsNullOrWhiteSpace(Model.Order.TrackingCode) ? "Đang cập nhật" : Model.Order.TrackingCode)</div>
                        <div class="col-md-12"><strong>Ghi chú:</strong> @(string.IsNullOrWhiteSpace(Model.Order.ShippingNote) ? "Không có" : Model.Order.ShippingNote)</div>
                    </div>
                </div>
            </div>
        }
    }
</div>
