@{
    Layout = null;
    var title = (string?)ViewBag.PolicyTitle ?? "Chính sách";
    var content = (string?)ViewBag.PolicyContent ?? "Chưa có nội dung.";
    var source = (string?)ViewBag.PolicySource ?? string.Empty;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - HoaXinh Store</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/style.css" />
    <link rel="stylesheet" href="~/storefront.css" />
</head>
<body class="nav-only-page">
    <partial name="Partials/_HeaderNavOnly" model='new HoaXinhStore.Web.ViewModels.StoreIndexViewModel()' />
    <main class="product-luxe-page">
        <div class="container py-4 py-lg-5">
            <section class="sidebar-box">
                <h1 class="products-luxe-title mb-3">@title</h1>
                <div class="policy-page-content">@Html.Raw(content)</div>
                @if (!string.IsNullOrWhiteSpace(source))
                {
                    <div class="mt-3">
                        <a href="@source" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm">Nguồn tham khảo</a>
                    </div>
                }
            </section>
        </div>
    </main>
    <partial name="Partials/_Footer" />
    <script src="~/storefront.js"></script>
</body>
</html>
