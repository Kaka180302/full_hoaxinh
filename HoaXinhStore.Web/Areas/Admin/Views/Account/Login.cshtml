@model HoaXinhStore.Web.ViewModels.Admin.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập quản trị</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; min-height: 100vh; font-family: 'Poppins', sans-serif; display: grid; place-items: center; background: linear-gradient(135deg, #55c8d8 0%, #7375e3 45%, #da2fd9 100%); position: relative; overflow: hidden; }
        .bg-shape { position: absolute; border-radius: 28px; opacity: .16; background: #ffffff; transform: rotate(32deg); }
        .shape-left { width: 360px; height: 360px; left: -120px; top: 80px; }
        .shape-right { width: 420px; height: 420px; right: -140px; bottom: 120px; }
        .login-card { width: min(92vw, 420px); background: #fff; border-radius: 12px; padding: 44px 40px 36px; box-shadow: 0 24px 50px rgba(36, 25, 79, 0.25); position: relative; z-index: 2; }
        .title { margin: 0 0 26px; text-align: center; font-size: 46px; font-weight: 700; letter-spacing: .5px; color: #1f1f1f; }
        .field { margin-bottom: 18px; }
        .field label { display: block; margin: 0 0 8px; color: #666; font-size: 14px; }
        .input-wrap { display: flex; align-items: center; gap: 8px; border-bottom: 1px solid #d9d9d9; padding-bottom: 8px; }
        .icon { width: 20px; color: #b2b2b2; font-size: 14px; text-align: center; }
        .input-wrap input { border: 0; outline: none; width: 100%; font-size: 15px; padding: 6px 0; color: #2c2c2c; font-family: inherit; }
        .input-wrap input::placeholder { color: #b3b3b3; }
        .btn-login { width: 100%; border: 0; border-radius: 28px; padding: 13px 18px; font-weight: 600; color: #fff; cursor: pointer; letter-spacing: .6px; background: linear-gradient(90deg, #5fd2d9, #6f8de8, #e02ee0); box-shadow: 0 6px 16px rgba(117, 77, 227, 0.35); }
        .errors { margin: 10px 0 14px; color: #d11a2a; font-size: 13px; min-height: 20px; }
        .errors ul { margin: 0; padding-left: 18px; }
        @@media (max-width: 480px) { .login-card { padding: 34px 24px 26px; } .title { font-size: 40px; } }
    </style>
</head>
<body>
    <div class="bg-shape shape-left"></div>
    <div class="bg-shape shape-right"></div>

    <div class="login-card">
        <h1 class="title">Đăng nhập</h1>

        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="field">
                <label asp-for="UsernameOrEmail">Tài khoản</label>
                <div class="input-wrap">
                    <span class="icon">&#128100;</span>
                    <input asp-for="UsernameOrEmail" placeholder="Nhập tên đăng nhập hoặc email" autocomplete="username" />
                </div>
            </div>

            <div class="field">
                <label asp-for="Password">Mật khẩu</label>
                <div class="input-wrap">
                    <span class="icon">&#128274;</span>
                    <input asp-for="Password" type="password" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                </div>
            </div>

            <div class="errors">
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div>@Model.ErrorMessage</div>
                }
                else if (!ViewData.ModelState.IsValid)
                {
                    <ul>
                        @foreach (var state in ViewData.ModelState.Values)
                        {
                            foreach (var err in state.Errors)
                            {
                                <li>@err.ErrorMessage</li>
                            }
                        }
                    </ul>
                }
            </div>

            <button class="btn-login" type="submit">ĐĂNG NHẬP</button>
        </form>
    </div>
</body>
</html>
