@model HoaXinhStore.Web.ViewModels.Admin.PaymentMethodSettingsViewModel
@{
    ViewData["Title"] = "Phương thức thanh toán";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">Phương thức thanh toán</h2>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form asp-action="Save" method="post" class="card p-3">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label d-block">Thanh toán khi nhận hàng (COD)</label>
            <input asp-for="CodEnabled" class="form-check-input" />
        </div>
        <div class="col-md-6">
            <label class="form-label d-block">Thanh toán online (VNPAY)</label>
            <input asp-for="VnPayEnabled" class="form-check-input" />
        </div>
        <div class="col-md-6">
            <label class="form-label d-block">Chuyển khoản QR (QRPAY)</label>
            <input asp-for="QrPayEnabled" class="form-check-input" />
        </div>
        <div class="col-md-6">
            <label class="form-label d-block">Thanh toán QR tự động (AUTOQR)</label>
            <input asp-for="AutoQrEnabled" class="form-check-input" />
        </div>
    </div>

    <div class="alert alert-info mt-3 mb-0">
        Khi tắt một phương thức, khách sẽ không thấy phương thức đó ở trang checkout và cũng không thể submit bằng phương thức đó.
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu cấu hình</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Tải lại</a>
    </div>
</form>

