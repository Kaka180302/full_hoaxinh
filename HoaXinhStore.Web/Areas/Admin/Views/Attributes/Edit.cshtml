@model HoaXinhStore.Web.ViewModels.Admin.ProductAttributeEditViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Thêm / Sửa thuộc tính" : "Thêm thuộc tính";
}
<h3>@ViewData["Title"]</h3>
<p class="text-muted">Cập nhật thuộc tính biến thể sản phẩm</p>

<form method="post" asp-action="Save" class="admin-card p-3">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Name" class="form-label">Tên thuộc tính</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-6">
            <label asp-for="SortOrder" class="form-label">Thứ tự</label>
            <input asp-for="SortOrder" class="form-control" />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Hiển thị</label>
            </div>
        </div>
    </div>

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Giá trị thuộc tính</h5>
        <button type="button" id="btnAddValue" class="btn btn-sm btn-outline-primary">+ Thêm giá trị</button>
    </div>
    <div id="valuesWrap" class="d-grid gap-2">
        @for (var i = 0; i < Model.Values.Count; i++)
        {
            <div class="row g-2 value-row">
                <input type="hidden" name="Values[@i].Id" value="@Model.Values[i].Id" />
                <div class="col-md-6"><input class="form-control" name="Values[@i].Value" value="@Model.Values[i].Value" placeholder="Tên giá trị" /></div>
                <div class="col-md-2"><input class="form-control" name="Values[@i].SortOrder" value="@Model.Values[i].SortOrder" type="number" /></div>
                <div class="col-md-2 d-flex align-items-center"><input class="form-check-input me-2" name="Values[@i].IsActive" type="checkbox" value="true" @(Model.Values[i].IsActive ? "checked" : "") /><label>Hiển thị</label></div>
                <div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 js-remove-value">Xóa</button></div>
            </div>
        }
    </div>

    <div asp-validation-summary="All" class="text-danger mt-2"></div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
    </div>
</form>

<script>
(() => {
    const wrap = document.getElementById('valuesWrap');
    const addBtn = document.getElementById('btnAddValue');
    if (!wrap || !addBtn) return;
    const reindex = () => {
        [...wrap.querySelectorAll('.value-row')].forEach((row, i) => {
            const inputs = row.querySelectorAll('input');
            if (inputs[0]) inputs[0].name = `Values[${i}].Id`;
            if (inputs[1]) inputs[1].name = `Values[${i}].Value`;
            if (inputs[2]) inputs[2].name = `Values[${i}].SortOrder`;
            if (inputs[3]) inputs[3].name = `Values[${i}].IsActive`;
        });
    };
    addBtn.addEventListener('click', () => {
        const row = document.createElement('div');
        row.className = 'row g-2 value-row';
        row.innerHTML = '<input type="hidden"><div class="col-md-6"><input class="form-control" placeholder="Tên giá trị"></div><div class="col-md-2"><input class="form-control" type="number" value="0"></div><div class="col-md-2 d-flex align-items-center"><input class="form-check-input me-2" type="checkbox" value="true" checked><label>Hiển thị</label></div><div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 js-remove-value">Xóa</button></div>';
        wrap.appendChild(row);
        reindex();
    });
    wrap.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-remove-value');
        if (!btn) return;
        btn.closest('.value-row')?.remove();
        reindex();
    });
    reindex();
})();
</script>

