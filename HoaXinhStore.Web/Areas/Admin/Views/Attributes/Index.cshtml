@model List<HoaXinhStore.Web.Entities.ProductAttribute>
@{
    ViewData["Title"] = "Quản lý thuộc tính";
}
<div class="admin-card p-3 mb-3">
    <h3 class="mb-1">Quản lý thuộc tính</h3>
    <p class="text-muted mb-0">Quản lý thuộc tính biến thể sản phẩm</p>
</div>

<form method="get" class="admin-card p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Tên thuộc tính</label>
            <input class="form-control" name="q" value="@ViewBag.Query" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Trạng thái</label>
            <select class="form-select" name="status">
                <option value="all" selected="@(ViewBag.Status == "all")">Tất cả trạng thái</option>
                <option value="active" selected="@(ViewBag.Status == "active")">Hiển thị</option>
                <option value="inactive" selected="@(ViewBag.Status == "inactive")">Ẩn</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Lọc</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Làm mới</a>
        </div>
    </div>
</form>

<div class="admin-card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Danh sách thuộc tính</h5>
        <a class="btn btn-success" asp-action="Create">+ Thêm thuộc tính</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Thuộc tính</th>
                    <th>Số giá trị</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Values.Count</td>
                        <td>@item.SortOrder</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Hiển thị</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">Ẩn</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            <form asp-action="ToggleActive" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-warning" type="submit">Đổi trạng thái</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

