@model HoaXinhStore.Web.ViewModels.Admin.ShippingSettingsViewModel
@{
    ViewData["Title"] = "GHN Tracking";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">GHN Tracking</h2>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form asp-action="Save" method="post" class="card p-3">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label d-block">Kích hoạt GHN</label>
            <input asp-for="GhnEnabled" class="form-check-input" />
        </div>
        <div class="col-md-3">
            <label class="form-label d-block">Tự cập nhật trạng thái đơn</label>
            <input asp-for="AutoUpdateOrderStatus" class="form-check-input" />
        </div>
        <div class="col-md-4">
            <label class="form-label d-block">COD: tự chuyển đã thanh toán khi giao thành công</label>
            <input asp-for="AutoMarkCodPaidWhenDelivered" class="form-check-input" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Tên hiển thị đơn vị vận chuyển</label>
            <input asp-for="DefaultCarrierDisplayName" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Webhook key (header: X-Shipping-Key)</label>
            <input asp-for="WebhookKey" class="form-control" />
        </div>
        <div class="col-12">
            <label class="form-label">Webhook URL (cấu hình trên GHN)</label>
            <input class="form-control" value="@Model.WebhookUrl" readonly />
        </div>
        <div class="col-12">
            <label class="form-label">Ghi chú quản trị</label>
            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Ví dụ: shopId/token GHN nội bộ"></textarea>
        </div>
    </div>

    <hr />
    <h6>Mapping trạng thái GHN -> đơn hàng</h6>
    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead>
                <tr>
                    <th>GHN/Webhook status</th>
                    <th>OrderStatus nội bộ</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>pending</td><td>Confirmed</td></tr>
                <tr><td>picked</td><td>Preparing</td></tr>
                <tr><td>shipping, in_transit</td><td>Shipping</td></tr>
                <tr><td>delivered</td><td>Completed</td></tr>
                <tr><td>failed</td><td>DeliveryFailed</td></tr>
                <tr><td>cancelled</td><td>Cancelled</td></tr>
                <tr><td>returned</td><td>Returned</td></tr>
            </tbody>
        </table>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu cấu hình</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Tải lại</a>
    </div>
</form>

