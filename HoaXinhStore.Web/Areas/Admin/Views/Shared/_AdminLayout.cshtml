@using Microsoft.AspNetCore.Identity
@using HoaXinhStore.Web.Entities.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg admin-topbar">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold d-flex align-items-center gap-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <img src="~/assets/img/logo/logoHX.png" alt="Hoa Xinh" style="width:34px;height:34px;object-fit:contain;" />
                <span>HoaXinh Admin</span>
            </a>
            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-3"></i>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="adminNavbar">
            <div class="d-flex text-white gap-3 align-items-center flex-wrap admin-top-links">
                <a class="text-decoration-none admin-nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-bar-chart-line-fill me-1"></i>Tổng quan</a>
                <div class="dropdown">
                    <a class="text-decoration-none admin-nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-box-seam me-1"></i>Kho sản phẩm
                    </a>
                    <ul class="dropdown-menu shadow-sm">
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Products" asp-action="Index"><i class="bi bi-bag me-2"></i>Quản lý sản phẩm</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Categories" asp-action="Index"><i class="bi bi-diagram-3 me-2"></i>Quản lý danh mục</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Brands" asp-action="Index"><i class="bi bi-award me-2"></i>Quản lý thương hiệu</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Attributes" asp-action="Index"><i class="bi bi-sliders me-2"></i>Quản lý thuộc tính</a></li>
                    </ul>
                </div>
                <a class="text-decoration-none admin-nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index"><i class="bi bi-receipt-cutoff me-1"></i>Đơn hàng</a>
                <div class="dropdown">
                    <a class="text-decoration-none admin-nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-gear me-1"></i>Hệ thống
                    </a>
                    <ul class="dropdown-menu shadow-sm">
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="HomeContent" asp-action="Index"><i class="bi bi-house-gear me-2"></i>Cấu hình trang chủ</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Policies" asp-action="Index"><i class="bi bi-shield-check me-2"></i>Chính sách</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="PaymentMethods" asp-action="Index"><i class="bi bi-credit-card-2-front me-2"></i>Phương thức thanh toán</a></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="ShippingSettings" asp-action="Index"><i class="bi bi-truck me-2"></i>GHN Tracking</a></li>
                    </ul>
                </div>
                <a class="text-decoration-none admin-nav-link" asp-area="Admin" asp-controller="Account" asp-action="Sessions"><i class="bi bi-clock-history me-1"></i>Lịch sử đăng nhập</a>
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-light">Đăng xuất</button>
                </form>
            </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const createPreviewBox = (input) => {
                const holder = document.createElement('div');
                holder.className = 'admin-upload-preview d-flex gap-2 flex-wrap mt-2';
                input.insertAdjacentElement('afterend', holder);
                return holder;
            };

            const renderPreview = (input) => {
                const targetSelector = input.getAttribute('data-preview-target');
                const target = targetSelector ? document.querySelector(targetSelector) : null;
                const files = Array.from(input.files || []).filter(f => /^image\//i.test(f.type));

                if (target) {
                    if (!files.length) return;
                    const file = files[0];
                    const url = URL.createObjectURL(file);
                    target.src = url;
                    target.style.display = '';
                    target.onload = () => URL.revokeObjectURL(url);
                    return;
                }

                let box = input.parentElement?.querySelector(':scope > .admin-upload-preview');
                if (!box) box = createPreviewBox(input);
                box.innerHTML = '';
                files.slice(0, 6).forEach(file => {
                    const url = URL.createObjectURL(file);
                    const img = document.createElement('img');
                    img.src = url;
                    img.alt = file.name;
                    img.style.cssText = 'width:76px;height:76px;object-fit:cover;border:1px solid #e5e7eb;border-radius:8px;background:#fff;';
                    img.onload = () => URL.revokeObjectURL(url);
                    box.appendChild(img);
                });
            };

            document.addEventListener('change', (e) => {
                const input = e.target.closest('input[type="file"]');
                if (!input) return;
                if (input.id === 'GalleryFiles') return;
                renderPreview(input);
            });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>

