@model List<HoaXinhStore.Web.Entities.Product>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<SelectListItem> ?? new List<SelectListItem>();
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var query = (string)ViewBag.Query;
    int? selectedCategory = ViewBag.CategoryId;
    var baseStockByProductId = ViewBag.BaseStockByProductId as Dictionary<int, int> ?? new Dictionary<int, int>();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản trị sản phẩm</h2>
    <a class="btn btn-primary" asp-action="Create">Thêm sản phẩm</a>
</div>
@if (TempData["ProductAdminMessage"] is string msg)
{
    var status = (TempData["ProductAdminStatus"] as string ?? "success").ToLowerInvariant();
    var cls = status == "error" ? "alert alert-danger" : "alert alert-success";
    <div class="@cls">@msg</div>
}
<form method="get" class="row g-2 mb-3">
    <div class="col-md-5"><input name="q" value="@query" class="form-control" placeholder="Tìm theo tên/SKU" /></div>
    <div class="col-md-4">
        <select name="categoryId" class="form-select">
            <option value="">-- Tất cả danh mục --</option>
            @foreach (var c in categories)
            {
                if (selectedCategory.HasValue && selectedCategory.Value.ToString() == c.Value)
                {
                    <option value="@c.Value" selected>@c.Text</option>
                }
                else
                {
                    <option value="@c.Value">@c.Text</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3"><button class="btn btn-outline-secondary w-100">Lọc</button></div>
</form>
<div class="table-responsive admin-table-scroll">
<table class="table table-striped table-bordered bg-white mb-0">
    <thead><tr><th>ID</th><th>Ảnh</th><th>SKU</th><th>Tên</th><th>Danh mục</th><th>Giá gốc</th><th>Giá KM</th><th>Tồn</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Id</td>
            <td><img src="@p.ImageUrl" style="width:56px;height:56px;object-fit:cover" /></td>
            <td>@p.Sku</td>
            <td>@p.Name</td>
            <td>@p.Category?.Name</td>
            <td>@p.Price.ToString("N0")</td>
            <td>@(p.SalePrice.HasValue ? p.SalePrice.Value.ToString("N0") : "-")</td>
            <td>
                @{
                    var activeVariants = (p.Variants ?? []).Where(v => v.IsActive).OrderByDescending(v => v.IsDefault).ThenBy(v => v.SortOrder).ThenBy(v => v.Id).ToList();
                    var defaultVariant = activeVariants.FirstOrDefault();
                    var baseStockVal = baseStockByProductId.TryGetValue(p.Id, out var bs) ? bs : p.StockQuantity;
                }
                @if (activeVariants.Count > 0)
                {
                    <div class="admin-stock-variant-wrap">
                        <select class="form-select form-select-sm admin-stock-variant-select" data-product-id="@p.Id">
                            @foreach (var v in activeVariants)
                            {
                                if (defaultVariant != null && v.Id == defaultVariant.Id)
                                {
                                    <option value="@v.Id" data-stock="@Math.Max(0, v.StockQuantity)" selected>
                                        @v.Name (@Math.Max(0, v.StockQuantity))
                                    </option>
                                }
                                else
                                {
                                    <option value="@v.Id" data-stock="@Math.Max(0, v.StockQuantity)">
                                        @v.Name (@Math.Max(0, v.StockQuantity))
                                    </option>
                                }
                            }
                        </select>
                    </div>
                }
                else
                {
                    <span>@Math.Max(0, baseStockVal)</span>
                }
            </td>
            <td>@(p.IsActive ? "Đang bán" : "Ngừng bán")</td>
            <td class="text-nowrap">
                <a class="btn btn-sm btn-info text-white" asp-action="Details" asp-route-id="@p.Id">Xem chi tiết</a>
                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@p.Id">Sửa</a>
                <form method="post" asp-action="ToggleActive" asp-route-id="@p.Id" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-dark" type="submit">Ẩn/Hiện</button>
                </form>
                <form method="post" asp-action="Delete" asp-route-id="@p.Id" class="d-inline js-confirm-delete" data-confirm-message="Xóa sản phẩm này? Hành động không thể hoàn tác.">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-danger js-open-confirm" type="button">Xóa</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-q="@query" asp-route-categoryId="@selectedCategory">@i</a></li>
        }
    </ul>
</nav>
<div class="hx-popup-backdrop" id="adminConfirmPopup" style="display:none;">
    <div class="hx-popup-card">
        <button type="button" class="hx-popup-close" id="adminConfirmClose">×</button>
        <div class="hx-popup-body">
            <h4>Xác nhận thao tác</h4>
            <p id="adminConfirmText">Bạn có chắc chắn muốn thực hiện thao tác này?</p>
            <div class="d-flex gap-2 justify-content-end">
                <button type="button" class="btn btn-outline-secondary" id="adminConfirmCancel">Hủy</button>
                <button type="button" class="btn btn-danger" id="adminConfirmOk">Xóa</button>
            </div>
        </div>
    </div>
</div>
<script>
(() => {
    const popup = document.getElementById('adminConfirmPopup');
    if (!popup) return;
    const text = document.getElementById('adminConfirmText');
    const btnOk = document.getElementById('adminConfirmOk');
    const btnClose = document.getElementById('adminConfirmClose');
    const btnCancel = document.getElementById('adminConfirmCancel');
    let pendingForm = null;
    const close = () => {
        popup.classList.remove('is-open');
        popup.style.display = 'none';
        pendingForm = null;
    };
    btnClose?.addEventListener('click', close);
    btnCancel?.addEventListener('click', close);
    popup.addEventListener('click', (e) => { if (e.target === popup) close(); });
    btnOk?.addEventListener('click', () => {
        if (pendingForm) pendingForm.submit();
        close();
    });
    document.querySelectorAll('.js-open-confirm').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            const form = btn.closest('.js-confirm-delete');
            if (!form) return;
            pendingForm = form;
            if (text) text.textContent = form.getAttribute('data-confirm-message') || 'Bạn có chắc chắn muốn xóa?';
            popup.style.display = 'flex';
            requestAnimationFrame(() => popup.classList.add('is-open'));
        });
    });
})();
</script>
