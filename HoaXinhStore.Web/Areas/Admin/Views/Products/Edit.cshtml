@model HoaXinhStore.Web.ViewModels.Admin.AdminProductEditViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Product" : "Create Product";
}
<h2>@ViewData["Title"]</h2>
<form method="post" asp-action="Save" enctype="multipart/form-data" class="bg-white p-3 border rounded">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-4"><label asp-for="Sku" class="form-label"></label><input asp-for="Sku" class="form-control" /></div>
        <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="CategoryId" class="form-label"></label><select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select"></select></div>
        <div class="col-md-4"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="StockQuantity" class="form-label"></label><input asp-for="StockQuantity" class="form-control" /></div>
        <div class="col-md-8"><label asp-for="ImageUrl" class="form-label"></label><input asp-for="ImageUrl" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="ImageFile" class="form-label"></label><input asp-for="ImageFile" class="form-control" type="file" /></div>
        <div class="col-12"><label asp-for="Summary" class="form-label"></label><textarea asp-for="Summary" class="form-control" rows="2"></textarea></div>
        <div class="col-12"><label asp-for="Descriptions" class="form-label"></label><textarea asp-for="Descriptions" class="form-control" rows="5"></textarea></div>
        <div class="col-12"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div></div>
    </div>
    <div asp-validation-summary="All" class="text-danger mt-2"></div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    </div>
</form>
