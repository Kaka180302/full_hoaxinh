@using System.Text.Json
@model HoaXinhStore.Web.ViewModels.Admin.AdminProductEditViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Sửa sản phẩm" : "Thêm sản phẩm";
    var attributes = ViewBag.Attributes ?? new List<object>();
    var attrJson = JsonSerializer.Serialize(attributes, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}
<h2>@ViewData["Title"]</h2>
<form method="post" asp-action="Save" enctype="multipart/form-data" class="admin-card p-3" id="productEditForm">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="StockQuantity" type="hidden" id="StockQuantityHidden" />
    <input asp-for="StockCase" type="hidden" value="0" />
    <input asp-for="StockPack" type="hidden" value="0" />
    <input asp-for="CaseFactor" type="hidden" value="0" />
    <input asp-for="PackFactor" type="hidden" value="0" />
    <input asp-for="DeletedVariantIdsCsv" type="hidden" id="DeletedVariantIds" value="" />

    <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">Thông tin chung</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-media" type="button">Hình ảnh</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-variants" type="button">Biến thể</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-content" type="button">Mô tả nội dung</button></li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-general">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Sku" class="form-label"></label>
                    <input asp-for="Sku" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="BrandId" class="form-label"></label>
                    <select asp-for="BrandId" asp-items="Model.BrandOptions" class="form-select"><option value="">-- Chọn thương hiệu --</option></select>
                </div>
                <input asp-for="Price" type="hidden" />
                <input asp-for="SalePrice" type="hidden" />
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-media">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="ImageFile" class="form-label"></label>
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" data-preview-target="#productMainPreview" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ảnh đại diện hiện tại</label>
                    <div>
                        <img id="productMainPreview"
                             src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "" : Model.ImageUrl)"
                             alt="Ảnh đại diện"
                             style="width:88px;height:88px;object-fit:cover;border-radius:10px;border:1px solid #e5e7eb;@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "display:none;" : "")" />
                    </div>
                </div>
                <div class="col-12">
                    <label asp-for="GalleryFiles" class="form-label"></label>
                    <input asp-for="GalleryFiles" class="form-control" type="file" accept="image/*" multiple />
                </div>
                @if (Model.GalleryImageUrls.Count > 0)
                {
                    <div class="col-12">
                        <label class="form-label">Ảnh con đã upload</label>
                        <div class="admin-upload-preview" style="display:flex;gap:8px;flex-wrap:wrap;">
                            @foreach (var g in Model.GalleryImageUrls)
                            {
                                <img src="@g" alt="Gallery" style="width:76px;height:76px;object-fit:cover;border:1px solid #e5e7eb;border-radius:8px;background:#fff;" />
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="tab-variants">
            <div class="admin-card p-3 mb-3">
                <h5 class="mb-3">Chọn thuộc tính</h5>
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Thuộc tính</label>
                        <select id="attributeSelect" class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Giá trị</label>
                        <div id="valuePicker" class="form-control p-1 hx-value-picker">
                            <div id="valueTags" class="d-flex flex-wrap gap-1"></div>
                            <input id="valueSearchInput" type="text" class="border-0 w-100 hx-value-input" placeholder="Chọn giá trị..." autocomplete="off" />
                            <div id="valueDropdown" class="hx-value-dropdown"></div>
                        </div>
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="button" id="btnAddAttributeGroup" class="btn btn-success">+ Thêm</button>
                    </div>
                </div>
                <div class="row g-2 align-items-end mt-2">
                    <div class="col-md-3">
                        <label class="form-label">Giá cơ sở (đơn vị hệ số 1)</label>
                        <input id="variantBasePrice" type="number" min="0" step="1" class="form-control" placeholder="vd: 8000" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tồn cơ sở (đơn vị hệ số 1)</label>
                        <input id="variantBaseStock" type="number" min="0" step="1" class="form-control" placeholder="vd: 120" />
                    </div>
                    <div class="col-md-6">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="autoCalcByFactor" checked />
                            <label class="form-check-label" for="autoCalcByFactor">Tự tính giá theo hệ số quy đổi đơn vị (không tự quy đổi tồn kho)</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Giá trị đã chọn cho từng thuộc tính</h5>
                    <div class="d-flex gap-2">
                        <button type="button" id="btnAddVariantRow" class="btn btn-outline-secondary">+ Thêm biến thể</button>
                        <button type="button" id="btnGenerateMatrix" class="btn btn-outline-primary">Tạo biến thể</button>
                    </div>
                </div>
                <div id="selectedAttributesWrap" class="d-grid gap-2 hx-selected-wrap"></div>
            </div>

            <div class="table-responsive admin-card p-2">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Tổ hợp thuộc tính</th>
                            <th>SKU</th>
                            <th>Giá *</th>
                            <th>Giá KM</th>
                            <th>Tồn kho *</th>
                            <th>Khối lượng (g)</th>
                            <th>Dài (cm)</th>
                            <th>Rộng (cm)</th>
                            <th>Cao (cm)</th>
                            <th>Ảnh biến thể</th>
                            <th>Mặc định</th>
                            <th>Ẩn/Hiện</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="variantWrap">
                        @for (var i = 0; i < Model.Variants.Count; i++)
                        {
                            <tr class="variant-row">
                                <td>
                                    <input type="hidden" name="Variants[@i].Id" value="@Model.Variants[i].Id" />
                                    <input class="form-control form-control-sm" name="Variants[@i].Name" value="@Model.Variants[i].Name" />
                                </td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].Sku" value="@Model.Variants[i].Sku" readonly /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].Price" value="@Model.Variants[i].Price" type="number" min="1" required /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].SalePrice" value="@Model.Variants[i].SalePrice" type="number" min="0" /></td>
                                <td><input class="form-control form-control-sm js-variant-stock" name="Variants[@i].StockQuantity" value="@Model.Variants[i].StockQuantity" type="number" min="0" required /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].WeightGram" value="@Model.Variants[i].WeightGram" type="number" min="0" /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].LengthMm" value="@Model.Variants[i].LengthMm" type="number" min="0" /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].WidthMm" value="@Model.Variants[i].WidthMm" type="number" min="0" /></td>
                                <td><input class="form-control form-control-sm" name="Variants[@i].HeightMm" value="@Model.Variants[i].HeightMm" type="number" min="0" /></td>
                                <td>
                                    <input type="hidden" name="Variants[@i].ImageUrl" value="@Model.Variants[i].ImageUrl" />
                                    <input class="form-control form-control-sm" type="file" name="VariantImageFiles[@i]" accept="image/*" data-preview-target="#variantPreview_@i" />
                                    <img id="variantPreview_@i"
                                         src="@(string.IsNullOrWhiteSpace(Model.Variants[i].ImageUrl) ? "" : Model.Variants[i].ImageUrl)"
                                         alt="Variant"
                                         style="margin-top:6px;width:52px;height:52px;object-fit:cover;border:1px solid #e5e7eb;border-radius:6px;@(string.IsNullOrWhiteSpace(Model.Variants[i].ImageUrl) ? "display:none;" : "")" />
                                </td>
                                <td>
                                    <input type="hidden" name="Variants[@i].SortOrder" value="@i" />
                                    <input class="form-check-input js-variant-default" name="Variants[@i].IsDefault" type="checkbox" value="true" @(Model.Variants[i].IsDefault ? "checked" : "") />
                                </td>
                                <td>
                                    <input class="form-check-input" name="Variants[@i].IsActive" type="checkbox" value="true" @(Model.Variants[i].IsActive ? "checked" : "") />
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger js-remove-variant">Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-content">
            <div class="row g-3">
                    <div class="col-12"><label asp-for="Summary" class="form-label"></label><textarea asp-for="Summary" class="form-control js-ckeditor-full" rows="4"></textarea></div>
                    <div class="col-12"><label asp-for="TechnicalSpecs" class="form-label"></label><textarea asp-for="TechnicalSpecs" class="form-control js-ckeditor-full" rows="3"></textarea></div>
                    <div class="col-12"><label asp-for="UsageGuide" class="form-label"></label><textarea asp-for="UsageGuide" class="form-control js-ckeditor-full" rows="3"></textarea></div>
                    <div class="col-12"><label asp-for="Descriptions" class="form-label"></label><textarea asp-for="Descriptions" class="form-control js-ckeditor-full" rows="8"></textarea></div>
                </div>
            </div>
        </div>

    <div asp-validation-summary="All" class="text-danger mt-2"></div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
    </div>
</form>

<style>
    .hx-value-picker { min-height: 44px; position: relative; }
    .hx-value-input { outline: none; padding: 2px 6px; }
    .hx-value-dropdown {
        position: absolute;
        left: -1px;
        right: -1px;
        top: calc(100% + 3px);
        z-index: 20;
        max-height: 230px;
        overflow: auto;
        display: none;
        background: #fff;
        border: 1px solid #e2d6c1;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,.09);
        padding: 6px;
    }
    .hx-value-dropdown .dropdown-item {
        border-radius: 8px;
        padding: 8px 10px;
        margin-bottom: 2px;
        text-align: left;
    }
    .hx-value-dropdown .dropdown-item.active {
        background: #eaf2ff;
        color: #24538c;
    }
    .hx-tag-chip {
        border: 1px solid #c8d3e2;
        border-radius: 8px;
        background: #f7fbff;
        color: #244466;
        padding: 2px 8px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .hx-tag-chip button { border: 0; background: transparent; color: #6f7f90; line-height: 1; }
    .hx-selected-row {
        display: grid;
        grid-template-columns: 170px 1fr;
        align-items: start;
        gap: 10px;
    }
    .hx-selected-row .hx-selected-name { display: flex; gap: 8px; align-items: center; font-weight: 700; }
    .hx-selected-row .hx-selected-values {
        min-height: 42px;
        border: 1px solid #d7dfeb;
        border-radius: 8px;
        background: #fff;
        padding: 6px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
</style>
<script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
<script>
    (function initAdminCkeditor() {
        const applyEditors = () => {
            if (!window.CKEDITOR) return;
            document.querySelectorAll('.js-ckeditor-full').forEach((el) => {
                if (!el.id) el.id = `ck_${Math.random().toString(36).slice(2, 10)}`;
                if (CKEDITOR.instances[el.id]) return;
                try {
                    CKEDITOR.replace(el.id, {
                        height: 220
                    });
                } catch (err) {
                    console.error('CKEditor init failed:', err);
                }
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', applyEditors, { once: true });
        } else {
            applyEditors();
        }

        document.querySelectorAll('[data-bs-toggle="tab"]').forEach((tabBtn) => {
            tabBtn.addEventListener('shown.bs.tab', () => {
                setTimeout(applyEditors, 0);
            });
        });
    })();

    (() => {
        const attributes = @Html.Raw(attrJson);
        const attrSelect = document.getElementById('attributeSelect');
        const valuePicker = document.getElementById('valuePicker');
        const valueTags = document.getElementById('valueTags');
        const valueSearchInput = document.getElementById('valueSearchInput');
        const valueDropdown = document.getElementById('valueDropdown');
        const addGroupBtn = document.getElementById('btnAddAttributeGroup');
        const selectedWrap = document.getElementById('selectedAttributesWrap');
        const matrixBtn = document.getElementById('btnGenerateMatrix');
        const addVariantRowBtn = document.getElementById('btnAddVariantRow');
        const variantWrap = document.getElementById('variantWrap');
        const deletedInput = document.getElementById('DeletedVariantIds');
        const basePriceInput = document.getElementById('variantBasePrice');
        const baseStockInput = document.getElementById('variantBaseStock');
        const autoCalcByFactorInput = document.getElementById('autoCalcByFactor');
        const skuInput = document.getElementById('Sku');
        const stockTotalHidden = document.getElementById('StockQuantityHidden');
        const form = document.getElementById('productEditForm');
        if (!attrSelect || !valuePicker || !valueTags || !valueSearchInput || !valueDropdown || !addGroupBtn || !selectedWrap || !matrixBtn || !variantWrap || !skuInput || !form || !stockTotalHidden) return;

        const state = { groups: [], pickedValues: [], activeDropdownIndex: -1 };
        const factorByValue = new Map();
        (attributes || []).forEach(a => (a.values || []).forEach(v => {
            const key = String(v.value || '').trim().toLowerCase();
            const f = Number(v.conversionFactor || 1);
            const safeFactor = f > 0 ? f : 1;
            if (!key) return;
            if (!factorByValue.has(key)) {
                factorByValue.set(key, safeFactor);
            } else {
                factorByValue.set(key, Math.min(factorByValue.get(key), safeFactor));
            }
        }));
        const deletedIds = new Set();
        const syncDeletedInput = () => {
            if (deletedInput) deletedInput.value = [...deletedIds].join(',');
        };

        const renderAttributeSelect = () => {
            attrSelect.innerHTML = '<option value="">-- Chọn thuộc tính --</option>';
            attributes.forEach(a => {
                const opt = document.createElement('option');
                opt.value = String(a.id);
                opt.textContent = a.name;
                attrSelect.appendChild(opt);
            });
        };

        const renderValueDropdown = () => {
            valueDropdown.innerHTML = '';
            const id = Number(attrSelect.value || 0);
            const attr = attributes.find(a => Number(a.id) === id);
            const keyword = (valueSearchInput.value || '').trim().toLowerCase();
            const rawValues = (attr?.values || []);
            const duplicateCount = rawValues.reduce((acc, v) => {
                const k = String(v.value || '').trim().toLowerCase();
                if (!k) return acc;
                acc[k] = (acc[k] || 0) + 1;
                return acc;
            }, {});
            const list = rawValues.filter(v => !keyword || String(v.value || '').toLowerCase().includes(keyword));
            state.activeDropdownIndex = list.length > 0 ? 0 : -1;
            list.forEach(v => {
                const rawValue = String(v.value || '').trim();
                const factor = Number(v.conversionFactor || 1);
                const safeFactor = factor > 0 ? factor : 1;
                const key = rawValue.toLowerCase();
                const shouldShowFactor = (duplicateCount[key] || 0) > 1;
                const displayText = shouldShowFactor ? `${rawValue} (x${safeFactor})` : rawValue;
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'dropdown-item';
                item.textContent = displayText;
                item.setAttribute('data-id', String(v.id));
                item.setAttribute('data-value', rawValue);
                item.setAttribute('data-display', displayText);
                item.setAttribute('data-factor', v.conversionFactor != null ? String(v.conversionFactor) : '');
                valueDropdown.appendChild(item);
            });
            [...valueDropdown.querySelectorAll('.dropdown-item')].forEach((el, idx) => el.classList.toggle('active', idx === state.activeDropdownIndex));
            valueDropdown.style.display = list.length > 0 ? 'block' : 'none';
        };

        const renderPickedTags = () => {
            valueTags.innerHTML = '';
            state.pickedValues.forEach((v, idx) => {
                const chip = document.createElement('span');
                chip.className = 'hx-tag-chip';
                const factorText = v.factor != null && Number(v.factor) > 0 ? ` <small>(x${v.factor})</small>` : '';
                chip.innerHTML = `${v.value}${factorText}<button type="button" data-remove-picked="${idx}">×</button>`;
                valueTags.appendChild(chip);
            });
        };

        const resetValuePicker = () => {
            state.pickedValues = [];
            valueSearchInput.value = '';
            renderPickedTags();
            renderValueDropdown();
        };

        const renderGroups = () => {
            selectedWrap.innerHTML = '';
            state.groups.forEach((g, i) => {
                const row = document.createElement('div');
                row.className = 'hx-selected-row';
                row.innerHTML = `<div class="hx-selected-name"><span>${g.name}</span><button type="button" class="btn btn-sm btn-outline-danger" data-remove="${i}">xóa</button></div><div class="hx-selected-values">${g.values.map(v => `<span class="hx-tag-chip">${v.value}</span>`).join("")}</div>`;
                selectedWrap.appendChild(row);
            });
        };

        const cartesian = (arrs) => arrs.reduce((a, b) => a.flatMap(d => b.map(e => [...d, e])), [[]]);
        const slug = (text) => (text || '')
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/đ/g, 'd').replace(/Đ/g, 'D')
            .toUpperCase().replace(/[^A-Z0-9]+/g, '_').replace(/^_+|_+$/g, '');
        const makeSku = (combo, idx) => `${(skuInput.value || 'SP-0').trim().toUpperCase()}-${combo.map(x => slug(x.value)).join('_') || `V${idx + 1}`}`;

        const existingKeys = () => {
            return new Set([...variantWrap.querySelectorAll('input[name*=".Name"]')]
                .map(i => (i.value || '').trim().toLowerCase())
                .filter(Boolean));
        };

        const createVariantRow = (idx, payload = {}) => {
            const rowFactor = Number(payload.factor || 1) > 0 ? Number(payload.factor) : 1;
            const tr = document.createElement('tr');
            tr.className = 'variant-row';
            tr.setAttribute('data-factor', String(rowFactor));
            tr.innerHTML = `<td><input type="hidden" name="Variants[${idx}].Id" value="${payload.id || ''}"><input class="form-control form-control-sm" name="Variants[${idx}].Name" value="${payload.name || ''}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].Sku" value="${payload.sku || ''}" readonly></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].Price" type="number" min="1" required value="${payload.price ?? ''}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].SalePrice" type="number" min="0" value="${payload.salePrice ?? ''}"></td>
<td><input class="form-control form-control-sm js-variant-stock" name="Variants[${idx}].StockQuantity" type="number" min="0" required value="${payload.stockQuantity ?? 0}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].WeightGram" type="number" min="0" value="${payload.weightGram ?? ''}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].LengthMm" type="number" min="0" value="${payload.lengthMm ?? ''}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].WidthMm" type="number" min="0" value="${payload.widthMm ?? ''}"></td>
<td><input class="form-control form-control-sm" name="Variants[${idx}].HeightMm" type="number" min="0" value="${payload.heightMm ?? ''}"></td>
<td><input type="hidden" name="Variants[${idx}].ImageUrl" value="${payload.imageUrl ?? ''}"><input class="form-control form-control-sm" type="file" accept="image/*" data-preview-target="#variantPreview_${idx}" name="VariantImageFiles[${idx}]"><img id="variantPreview_${idx}" src="${payload.imageUrl ?? ''}" alt="Variant" style="margin-top:6px;width:52px;height:52px;object-fit:cover;border:1px solid #e5e7eb;border-radius:6px;${payload.imageUrl ? '' : 'display:none;'}"></td>
<td><input type="hidden" name="Variants[${idx}].SortOrder" value="${idx}"><input class="form-check-input js-variant-default" name="Variants[${idx}].IsDefault" type="checkbox" value="true" ${payload.isDefault === true ? 'checked' : ''}></td>
<td><input class="form-check-input" name="Variants[${idx}].IsActive" type="checkbox" value="true" ${payload.isActive === false ? '' : 'checked'}></td>
<td><button type="button" class="btn btn-sm btn-outline-danger js-remove-variant">Xóa</button></td>`;
            variantWrap.appendChild(tr);
        };

        const parseVariantFactorByName = (name) => {
            const parts = String(name || '').split(' - ').map(x => x.trim()).filter(Boolean);
            if (!parts.length) return 1;
            let factor = 1;
            parts.forEach(part => {
                const explicit = part.match(/\(x\s*(\d+)\s*\)/i);
                if (explicit && explicit[1]) {
                    const fExp = Number(explicit[1]);
                    if (fExp > 0) {
                        factor *= fExp;
                        return;
                    }
                }
                const cleaned = part.replace(/\(x\s*\d+\s*\)/ig, '').trim().toLowerCase();
                const f = Number(factorByValue.get(cleaned) || 1);
                if (f > 0) factor *= f;
            });
            return factor > 0 ? factor : 1;
        };

        const applyAutoStockMode = () => {
            const rows = [...variantWrap.querySelectorAll('tr.variant-row')];
            if (!rows.length) {
                syncTotalStock();
                return;
            }

            // Sync factor from row name/data first.
            rows.forEach((tr) => {
                const nameInput = tr.querySelector('input[name*=".Name"]');
                const fromData = Number(tr.getAttribute('data-factor') || 0);
                const fromName = parseVariantFactorByName(nameInput?.value || '');
                const factor = fromData > 0 ? fromData : fromName;
                tr.setAttribute('data-factor', String(Math.max(1, factor)));
            });

            // Không tự khóa hay tự quy đổi tồn kho: admin nhập trực tiếp từng biến thể.
            rows.forEach((tr) => {
                const stockInput = tr.querySelector('input[name*=".StockQuantity"]');
                if (!stockInput) return;
                stockInput.readOnly = false;
                stockInput.classList.remove('bg-light');
            });

            syncTotalStock();
        };

        const reindexRows = () => {
            [...variantWrap.querySelectorAll('tr.variant-row')].forEach((tr, idx) => {
                tr.querySelectorAll('input,select,textarea').forEach(el => {
                    const n = el.getAttribute('name');
                    if (!n) return;
                    el.setAttribute('name', n.replace(/Variants\[\d+\]/, `Variants[${idx}]`));
                });
                const sort = tr.querySelector('input[name*=".SortOrder"]');
                if (sort) sort.value = String(idx);
            });
            syncDeletedInput();
        };

        const buildMatrix = () => {
            if (state.groups.length === 0) return;
            const combos = cartesian(state.groups.map(g => g.values));
            const keys = existingKeys();
            let nextIndex = variantWrap.querySelectorAll('tr.variant-row').length;
            const autoCalc = !!autoCalcByFactorInput?.checked;
            const basePrice = Math.max(0, Number(basePriceInput?.value || 0));
            const baseStock = Math.max(0, Number(baseStockInput?.value || 0));
            combos.forEach((combo) => {
                const name = combo.map(x => x.value).join(' - ');
                const key = name.trim().toLowerCase();
                if (keys.has(key)) return;
                const factor = combo.reduce((acc, x) => {
                    const f = Number(x.factor || 0);
                    return f > 0 ? acc * f : acc;
                }, 1);
                const calculatedPrice = autoCalc ? Math.round(basePrice * Math.max(1, factor)) : '';
            const calculatedStock = 0;
            createVariantRow(nextIndex++, {
                name,
                sku: makeSku(combo, nextIndex),
                price: calculatedPrice,
                    stockQuantity: calculatedStock,
                    factor
                });
                keys.add(key);
            });
            reindexRows();
            applyAutoStockMode();
            syncTotalStock();
        };

        const syncTotalStock = () => {
            const total = [...variantWrap.querySelectorAll('input[name*=".StockQuantity"]')].reduce((s, x) => s + Math.max(0, Number(x.value || 0)), 0);
            stockTotalHidden.value = String(total);
        };

        addGroupBtn.addEventListener('click', () => {
            const attrId = Number(attrSelect.value || 0);
            if (!attrId) return;
            const attr = attributes.find(a => Number(a.id) === attrId);
            if (!attr) return;
            const picked = state.pickedValues;
            if (picked.length === 0) return;
            const existedIndex = state.groups.findIndex(g => Number(g.id) === attrId);
            if (existedIndex >= 0) state.groups.splice(existedIndex, 1);
            state.groups.push({ id: attr.id, name: attr.name, values: picked });
            renderGroups();
            resetValuePicker();
        });

        selectedWrap.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-remove]');
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-remove'));
            if (idx >= 0) state.groups.splice(idx, 1);
            renderGroups();
        });

        matrixBtn.addEventListener('click', buildMatrix);
        addVariantRowBtn?.addEventListener('click', () => {
            const idx = variantWrap.querySelectorAll('tr.variant-row').length;
            createVariantRow(idx, { name: 'Biến thể mới', sku: makeSku([], idx) });
            reindexRows();
            applyAutoStockMode();
            syncTotalStock();
        });
        variantWrap.addEventListener('click', (e) => {
            const btn = e.target.closest('.js-remove-variant');
            if (!btn) return;
            const row = btn.closest('tr.variant-row');
            if (!row) return;
            const idInput = row.querySelector('input[name*=".Id"]');
            const activeInput = row.querySelector('input[name*=".IsActive"]');
            const hasId = !!(idInput && String(idInput.value || '').trim());
            if (hasId) {
                deletedIds.add(Number(idInput.value));
                row.remove();
                reindexRows();
            } else {
                row.remove();
                reindexRows();
            }
            syncTotalStock();
        });
        variantWrap.addEventListener('change', (e) => {
            const defaultBox = e.target.closest('.js-variant-default');
            if (defaultBox && defaultBox.checked) {
                variantWrap.querySelectorAll('.js-variant-default').forEach((cb) => {
                    if (cb !== defaultBox) cb.checked = false;
                });
            }
        });
        variantWrap.addEventListener('input', syncTotalStock);
        variantWrap.addEventListener('input', (e) => {
            if (e.target?.matches('input[name*=".Name"]')) {
                const tr = e.target.closest('tr.variant-row');
                if (tr) {
                    const factor = parseVariantFactorByName(e.target.value || '');
                    tr.setAttribute('data-factor', String(factor));
                    applyAutoStockMode();
                }
            }
        });
        baseStockInput?.addEventListener('input', syncTotalStock);
        autoCalcByFactorInput?.addEventListener('change', applyAutoStockMode);
        form.addEventListener('submit', syncTotalStock);
        form.addEventListener('submit', syncDeletedInput);
        form.addEventListener('submit', () => {
            // Ensure unchecked variant checkboxes still post "false" values.
            form.querySelectorAll('input[type="hidden"][data-generated-bool="1"]').forEach(x => x.remove());
            form.querySelectorAll('input.form-check-input[name*=".IsActive"], input.form-check-input[name*=".IsDefault"]').forEach(cb => {
                if (!cb.name || cb.disabled || cb.checked) return;
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = cb.name;
                hidden.value = 'false';
                hidden.setAttribute('data-generated-bool', '1');
                cb.insertAdjacentElement('afterend', hidden);
            });

            const rows = [...variantWrap.querySelectorAll('tr.variant-row')];
            const visibleRows = rows.filter(r => r.querySelector('input[name*=".IsActive"]')?.checked);
            if (!visibleRows.length) return;
            const selectedDefault = visibleRows.find(r => r.querySelector('.js-variant-default')?.checked);
            if (!selectedDefault) {
                const firstDefault = visibleRows[0].querySelector('.js-variant-default');
                if (firstDefault) firstDefault.checked = true;
            }
            const activeDefault = visibleRows.find(r => r.querySelector('.js-variant-default')?.checked);
            if (activeDefault) {
                rows.forEach(r => {
                    const cb = r.querySelector('.js-variant-default');
                    if (cb && r !== activeDefault) cb.checked = false;
                });
            }
        });
        valuePicker.addEventListener('click', () => {
            renderValueDropdown();
            valueSearchInput.focus();
        });
        valueSearchInput.addEventListener('focus', renderValueDropdown);
        valueSearchInput.addEventListener('input', renderValueDropdown);
        valueSearchInput.addEventListener('keydown', (e) => {
            const items = [...valueDropdown.querySelectorAll('.dropdown-item')];
            if (items.length === 0) return;
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                state.activeDropdownIndex = (state.activeDropdownIndex + 1) % items.length;
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                state.activeDropdownIndex = (state.activeDropdownIndex - 1 + items.length) % items.length;
            } else if (e.key === 'Enter') {
                e.preventDefault();
                const item = items[state.activeDropdownIndex] || items[0];
                item?.click();
                return;
            } else {
                return;
            }
            items.forEach((el, idx) => el.classList.toggle('active', idx === state.activeDropdownIndex));
            items[state.activeDropdownIndex]?.scrollIntoView({ block: 'nearest' });
        });
        attrSelect.addEventListener('change', resetValuePicker);
        valueDropdown.addEventListener('click', (e) => {
            const item = e.target.closest('.dropdown-item');
            if (!item) return;
            const id = Number(item.getAttribute('data-id') || 0);
            const value = item.getAttribute('data-value') || '';
            const display = item.getAttribute('data-display') || value;
            const factorRaw = item.getAttribute('data-factor');
            const factor = factorRaw != null && factorRaw !== '' ? Number(factorRaw) : null;
            if (!id || !value) return;
            if (!state.pickedValues.some(x => Number(x.id) === id)) {
                state.pickedValues.push({ id, value: display, factor });
                renderPickedTags();
            }
            valueSearchInput.value = '';
            renderValueDropdown();
            valueSearchInput.focus();
        });
        valueTags.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-remove-picked]');
            if (!btn) return;
            const idx = Number(btn.getAttribute('data-remove-picked'));
            if (idx >= 0) {
                state.pickedValues.splice(idx, 1);
                renderPickedTags();
            }
        });
        document.addEventListener('click', (e) => {
            if (!valuePicker.contains(e.target)) {
                valueDropdown.style.display = 'none';
                state.activeDropdownIndex = -1;
            }
        });
        renderAttributeSelect();
        resetValuePicker();
        [...variantWrap.querySelectorAll('tr.variant-row')].forEach((tr) => {
            const nameInput = tr.querySelector('input[name*=".Name"]');
            const factor = parseVariantFactorByName(nameInput?.value || '');
            tr.setAttribute('data-factor', String(factor));
        });
        applyAutoStockMode();
        syncTotalStock();
    })();
</script>
<script>
    (() => {
        const input = document.getElementById('GalleryFiles');
        if (!input) return;
        input.multiple = true;
        const dt = new DataTransfer();
        const seen = new Set();
        const previewHost = document.createElement('div');
        previewHost.className = 'admin-upload-preview mt-2';
        previewHost.style.display = 'flex';
        previewHost.style.gap = '8px';
        previewHost.style.flexWrap = 'wrap';
        input.insertAdjacentElement('afterend', previewHost);

        const fileKey = (file) => `${file.name}__${file.size}__${file.lastModified}`;
        const syncInputFiles = () => {
            input.files = dt.files;
        };

        const renderPreview = () => {
            previewHost.innerHTML = '';
            [...dt.files].forEach((file, idx) => {
                const wrap = document.createElement('div');
                wrap.style.position = 'relative';
                wrap.style.width = '76px';
                wrap.style.height = '76px';
                const img = document.createElement('img');
                img.style.width = '76px';
                img.style.height = '76px';
                img.style.objectFit = 'cover';
                img.style.border = '1px solid #e5e7eb';
                img.style.borderRadius = '8px';
                const remove = document.createElement('button');
                remove.type = 'button';
                remove.textContent = '×';
                remove.style.position = 'absolute';
                remove.style.top = '-6px';
                remove.style.right = '-6px';
                remove.style.width = '20px';
                remove.style.height = '20px';
                remove.style.border = 'none';
                remove.style.borderRadius = '50%';
                remove.style.background = '#dc3545';
                remove.style.color = '#fff';
                remove.style.fontSize = '12px';
                remove.addEventListener('click', () => {
                    const next = new DataTransfer();
                    seen.clear();
                    [...dt.files].forEach((f, i) => {
                        if (i !== idx) {
                            next.items.add(f);
                            seen.add(fileKey(f));
                        }
                    });
                    dt.items.clear();
                    [...next.files].forEach(f => dt.items.add(f));
                    syncInputFiles();
                    renderPreview();
                });
                const reader = new FileReader();
                reader.onload = e => { img.src = String(e.target?.result || ''); };
                reader.readAsDataURL(file);
                wrap.appendChild(img);
                wrap.appendChild(remove);
                previewHost.appendChild(wrap);
            });
        };

        input.addEventListener('change', () => {
            [...(input.files || [])].forEach(file => {
                const key = fileKey(file);
                if (seen.has(key)) return;
                seen.add(key);
                dt.items.add(file);
            });
            syncInputFiles();
            renderPreview();
            input.value = '';
        });
    })();
</script>
