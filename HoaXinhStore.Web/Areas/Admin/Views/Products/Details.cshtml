@model HoaXinhStore.Web.Entities.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Chi tiết sản phẩm</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
        <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border" />
            </div>
            <div class="col-md-9">
                <div class="row g-2">
                    <div class="col-md-6"><strong>ID:</strong> @Model.Id</div>
                    <div class="col-md-6"><strong>SKU:</strong> @Model.Sku</div>
                    <div class="col-md-6"><strong>Tên:</strong> @Model.Name</div>
                    <div class="col-md-6"><strong>Danh mục:</strong> @Model.Category?.Name</div>
                    <div class="col-md-6"><strong>Giá bán:</strong> @Model.Price.ToString("N0") đ</div>
                    <div class="col-md-6"><strong>Tồn kho:</strong> @Model.StockQuantity</div>
                    <div class="col-md-6"><strong>Trạng thái:</strong> @(Model.IsActive ? "Đang bán" : "Ngừng bán")</div>
                </div>
            </div>
            <div class="col-12">
                <h5 class="mt-3">Mô tả ngắn</h5>
                <p class="mb-0">@Model.Summary</p>
            </div>
            <div class="col-12">
                <h5 class="mt-3">Mô tả chi tiết</h5>
                <p class="mb-0" style="white-space: pre-line;">@Model.Descriptions</p>
            </div>
        </div>
    </div>
</div>
