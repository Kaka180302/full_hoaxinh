@{
    ViewData["Title"] = "Tổng quan";
    var lowStockVariants = ViewBag.LowStockVariants as List<HoaXinhStore.Web.Entities.ProductVariant> ?? new();
}
<h2 class="mb-4">Tổng quan</h2>
<div class="row g-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Sản phẩm</div><h4>@ViewBag.ProductCount</h4></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Danh mục</div><h4>@ViewBag.CategoryCount</h4></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Đơn hàng</div><h4>@ViewBag.OrderCount</h4></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Chờ xác nhận</div><h4>@ViewBag.PendingOrderCount</h4></div></div></div>
    <div class="col-md-3"><div class="card border-warning"><div class="card-body"><div class="text-muted">Tồn kho thấp (&lt;10)</div><h4 class="text-warning">@ViewBag.LowStockCount</h4></div></div></div>
    <div class="col-md-3"><div class="card border-success"><div class="card-body"><div class="text-muted">Doanh thu 30 ngày</div><h4 class="text-success">@(((decimal)ViewBag.Revenue30Days).ToString("N0")) đ</h4></div></div></div>
    <div class="col-md-3"><div class="card border-info"><div class="card-body"><div class="text-muted">Đơn hoàn thành 30 ngày</div><h4 class="text-info">@ViewBag.Completed30Days</h4></div></div></div>
    <div class="col-md-3"><div class="card border-primary"><div class="card-body"><div class="text-muted">AOV 30 ngày</div><h4 class="text-primary">@(((decimal)ViewBag.Aov30Days).ToString("N0")) đ</h4></div></div></div>
</div>

@if (lowStockVariants.Any())
{
    <div class="card mt-4">
        <div class="card-header fw-semibold">Biến thể sắp hết hàng</div>
        <div class="card-body p-0">
            <table class="table table-striped table-bordered mb-0">
                <thead><tr><th>SKU biến thể</th><th>Sản phẩm</th><th>Biến thể</th><th>Danh mục</th><th>Tồn khả dụng</th><th></th></tr></thead>
                <tbody>
                @foreach (var v in lowStockVariants)
                {
                    <tr>
                        <td>@v.Sku</td>
                        <td>@v.Product?.Name</td>
                        <td>@v.Name</td>
                        <td>@v.Product?.Category?.Name</td>
                        <td class="text-danger fw-bold">@v.AvailableStock</td>
                        <td><a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@v.ProductId" class="btn btn-sm btn-warning">Sửa</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@{
    var topProducts = ViewBag.TopProducts as IEnumerable<dynamic> ?? [];
}
@if (topProducts.Any())
{
    <div class="card mt-4">
        <div class="card-header fw-semibold">Top sản phẩm 30 ngày</div>
        <div class="card-body p-0">
            <table class="table table-striped table-bordered mb-0">
                <thead><tr><th>Tên</th><th>SL bán</th><th>Doanh thu</th></tr></thead>
                <tbody>
                @foreach (var p in topProducts)
                {
                    <tr>
                        <td>@p.ProductNameSnapshot</td>
                        <td>@p.Qty</td>
                        <td>@(((decimal)p.Revenue).ToString("N0")) đ</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
